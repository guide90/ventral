{%- liquid
  assign hero_image = section.settings.hero_image
  assign who_image = section.settings.who_image
  assign today_image = section.settings.today_image
  assign future_image = section.settings.future_image
  assign today_background = section.settings.today_background
  assign video_poster = section.settings.video_poster
  assign cta_image = section.settings.cta_image
-%}

<section class="story-page story-page--{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="story-page__hero">
    {%- if hero_image != blank -%}
      {{
        hero_image
        | image_url: width: 3000
        | image_tag:
          class: 'story-page__media',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000, 3000'
      }}
    {%- endif -%}
    <h1 class="story-page__hero-title">{{ section.settings.hero_title | escape }}</h1>
  </div>

  <div class="story-page__intro">
    <div class="story-page__container story-page__intro-grid">
      <div class="story-page__intro-copy">
        <h2>{{ section.settings.intro_heading | escape }}</h2>
        <div class="story-page__rte">{{ section.settings.intro_text }}</div>
      </div>
      <div class="story-page__intro-image story-page__rounded-image">
        {%- if who_image != blank -%}
          {{ who_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '700, 1000, 1600' }}
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="story-page__mission">
    {%- if today_background != blank -%}
      {{
        today_background
        | image_url: width: 3000
        | image_tag: class: 'story-page__mission-background', loading: 'lazy', widths: '750, 1200, 1800, 2400, 3000'
      }}
    {%- endif -%}
    <div class="story-page__container story-page__mission-grid">
      <article class="story-page__mission-item">
        <div class="story-page__rounded-image">
          {%- if today_image != blank -%}
            {{ today_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '700, 1000, 1600' }}
          {%- endif -%}
        </div>
        <div class="story-page__mission-copy">
          <p class="story-page__eyebrow">{{ section.settings.today_eyebrow | escape }}</p>
          <h2>{{ section.settings.today_heading | escape }}</h2>
          <p>{{ section.settings.today_text | escape }}</p>
        </div>
      </article>
      <article class="story-page__mission-item story-page__mission-item--future">
        <div class="story-page__rounded-image">
          {%- if future_image != blank -%}
            {{ future_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '700, 1000, 1600' }}
          {%- endif -%}
        </div>
        <div class="story-page__mission-copy">
          <p class="story-page__eyebrow">{{ section.settings.future_eyebrow | escape }}</p>
          <h2>{{ section.settings.future_heading | escape }}</h2>
          <p>{{ section.settings.future_text | escape }}</p>
        </div>
      </article>
    </div>
  </div>

  <div class="story-page__technology">
    <div class="story-page__container">
      <p class="story-page__eyebrow">{{ section.settings.technology_eyebrow | escape }}</p>
      <h2 class="story-page__technology-heading">
        <span class="story-page__technology-heading-desktop">
          {{- section.settings.technology_heading | escape | newline_to_br -}}
        </span>
        <span class="story-page__technology-heading-mobile">
          {{- section.settings.technology_heading_mobile | escape -}}
        </span>
      </h2>
      <div class="story-page__feature-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <article class="story-page__feature-card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1600
                  | image_tag: class: 'story-page__feature-image', loading: 'lazy', widths: '700, 1000, 1600'
                }}
              {%- endif -%}
              <div class="story-page__feature-overlay"></div>
              <div class="story-page__feature-content">
                <h3>{{ block.settings.heading | escape }}</h3>
                <p>{{ block.settings.text | escape }}</p>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="story-page__video">
    {%- if section.settings.video != blank -%}
      {{
        section.settings.video
        | video_tag:
          class: 'story-page__video-element',
          image_size: '2000x',
          autoplay: true,
          loop: true,
          muted: true,
          controls: true,
          playsinline: true
      }}
    {%- elsif section.settings.video_url != blank -%}
      <video
        class="story-page__video-element"
        {% if video_poster != blank %}
          poster="{{ video_poster | image_url: width: 2000 }}"
        {% endif %}
        controls
        playsinline
        preload="metadata"
      >
        <source src="{{ section.settings.video_url | escape }}" type="video/mp4">
      </video>
    {%- elsif video_poster != blank -%}
      {{
        video_poster
        | image_url: width: 2400
        | image_tag: class: 'story-page__media', loading: 'lazy', widths: '750, 1200, 1800, 2400'
      }}
    {%- endif -%}
  </div>

  <div class="story-page__cta">
    {%- if cta_image != blank -%}
      {{
        cta_image
        | image_url: width: 3000
        | image_tag: class: 'story-page__media', loading: 'lazy', widths: '750, 1200, 1800, 2400, 3000'
      }}
    {%- endif -%}
    <div class="story-page__cta-overlay"></div>
    <div class="story-page__container story-page__cta-content">
      <h2>{{ section.settings.cta_heading | escape }}</h2>
      <p>{{ section.settings.cta_text | escape }}</p>
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a class="story-page__cta-button" href="{{ section.settings.cta_link }}">
          {{- section.settings.cta_label | escape -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  .story-page--{{ section.id }} { --story-blue: #3983fb; --story-navy: #001326; --story-ink: #06142e; --story-muted: #a5a9b7; font-family: Roboto, Arial, sans-serif; overflow: hidden; }
  .story-page--{{ section.id }} *, .story-page--{{ section.id }} *::before, .story-page--{{ section.id }} *::after { box-sizing: border-box; }
  .story-page--{{ section.id }} h1, .story-page--{{ section.id }} h2, .story-page--{{ section.id }} h3, .story-page--{{ section.id }} p { margin: 0; }
  .story-page--{{ section.id }} img, .story-page--{{ section.id }} video { display: block; max-width: 100%; }
  .story-page--{{ section.id }} .story-page__container { width: min(100% - 48px, 1440px); margin: 0 auto; }
  .story-page--{{ section.id }} .story-page__hero, .story-page--{{ section.id }} .story-page__cta { position: relative; isolation: isolate; color: #fff; overflow: hidden; }
  .story-page--{{ section.id }} .story-page__hero { min-height: min(56.25vw, 900px); display: grid; place-items: center; background: #0a1c2a; }
  .story-page--{{ section.id }} .story-page__media, .story-page--{{ section.id }} .story-page__mission-background { width: 100%; height: 100%; object-fit: cover; }
  .story-page--{{ section.id }} .story-page__hero > .story-page__media { position: absolute; inset: 0; z-index: -2; }
  .story-page--{{ section.id }} .story-page__hero::after { content: ''; position: absolute; inset: 0; z-index: -1; background: rgba(0, 18, 35, .16); }
  .story-page--{{ section.id }} .story-page__hero-title { padding: 40px 24px; font-size: clamp(42px, 5.2vw, 80px); line-height: 1.1; font-weight: 800; text-align: center; letter-spacing: -.05em; }
  .story-page--{{ section.id }} .story-page__intro { padding: clamp(72px, 10vw, 160px) 0; color: #fff; background: var(--story-navy); }
  .story-page--{{ section.id }} .story-page__intro-grid { display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: clamp(48px, 9vw, 150px); }
  .story-page--{{ section.id }} .story-page__intro-copy h2, .story-page--{{ section.id }} .story-page__technology-heading { font-size: clamp(42px, 4.1vw, 64px); line-height: 1; font-weight: 800; letter-spacing: -.04em; }
  .story-page--{{ section.id }} .story-page__rte { margin-top: 32px; font-size: 16px; line-height: 1.55; color: rgba(255,255,255,.88); }
  .story-page--{{ section.id }} .story-page__rte p + p { margin-top: 1em; }
  .story-page--{{ section.id }} .story-page__rounded-image { position: relative; overflow: hidden; border-radius: 20px; background: rgba(255,255,255,.16); }
  .story-page--{{ section.id }} .story-page__rounded-image img { width: 100%; height: 100%; object-fit: cover; }
  .story-page--{{ section.id }} .story-page__intro-image { min-height: 430px; }
  .story-page--{{ section.id }} .story-page__mission { position: relative; overflow: hidden; padding: clamp(80px, 10vw, 150px) 0; background: #f5f7fb; }
  .story-page--{{ section.id }} .story-page__mission-background { position: absolute; inset: 0; opacity: .2; }
  .story-page--{{ section.id }} .story-page__mission-grid { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: clamp(38px, 7vw, 110px); }
  .story-page--{{ section.id }} .story-page__mission-item { display: flex; flex-direction: column; gap: 32px; }
  .story-page--{{ section.id }} .story-page__mission-item .story-page__rounded-image { height: clamp(260px, 26vw, 420px); box-shadow: 7px 7px 24px rgba(142,194,215,.46); background: #fff; }
  .story-page--{{ section.id }} .story-page__mission-copy { color: var(--story-muted); }
  .story-page--{{ section.id }} .story-page__eyebrow { color: var(--story-blue); font-size: 14px; line-height: 1.1; font-weight: 800; }
  .story-page--{{ section.id }} .story-page__mission-copy h2 { margin: 15px 0 20px; color: var(--story-ink); font-size: clamp(34px, 3.35vw, 54px); line-height: 1; font-weight: 800; letter-spacing: -.045em; }
  .story-page--{{ section.id }} .story-page__mission-copy > p:last-child { max-width: 530px; font-size: 18px; line-height: 1.5; }
  .story-page--{{ section.id }} .story-page__technology { padding: clamp(80px, 10vw, 150px) 0; color: #fff; background: #0c0e12; }
  .story-page--{{ section.id }} .story-page__technology-heading { margin: 18px 0 52px; }
  .story-page--{{ section.id }} .story-page__feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .story-page--{{ section.id }} .story-page__feature-card { position: relative; min-height: 340px; overflow: hidden; border-radius: 20px; background: #19303e; }
  .story-page--{{ section.id }} .story-page__feature-image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .story-page--{{ section.id }} .story-page__feature-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,5,9,.8), rgba(0,38,56,.16)); }
  .story-page--{{ section.id }} .story-page__feature-content { position: absolute; right: 28px; bottom: 28px; left: 28px; }
  .story-page--{{ section.id }} .story-page__feature-content h3 { font-size: clamp(26px, 2.2vw, 36px); line-height: 1; font-weight: 800; letter-spacing: -.04em; }
  .story-page--{{ section.id }} .story-page__feature-content p { margin-top: 15px; max-width: 480px; color: rgba(255,255,255,.8); font-size: 16px; line-height: 1.45; }
  .story-page--{{ section.id }} .story-page__video { position: relative; aspect-ratio: 1920 / 1080; background: #07101f; }
  .story-page--{{ section.id }} .story-page__video-element { width: 100%; height: 100%; object-fit: cover; }
  .story-page--{{ section.id }} .story-page__cta { min-height: clamp(500px, 48vw, 740px); display: flex; align-items: center; background: #002543; }
  .story-page--{{ section.id }} .story-page__cta > .story-page__media { position: absolute; inset: 0; z-index: -2; }
  .story-page--{{ section.id }} .story-page__cta-overlay { position: absolute; inset: 0; z-index: -1; background: linear-gradient(90deg, rgba(0,37,67,.96), rgba(1,12,21,.08)); }
  .story-page--{{ section.id }} .story-page__cta-content { max-width: 1440px; }
  .story-page--{{ section.id }} .story-page__cta-content h2 { max-width: 670px; font-size: clamp(44px, 5vw, 80px); line-height: 1.05; font-weight: 800; letter-spacing: -.05em; }
  .story-page--{{ section.id }} .story-page__cta-content p { margin-top: 24px; max-width: 540px; color: rgba(255,255,255,.8); font-size: 18px; line-height: 1.5; }
  .story-page--{{ section.id }} .story-page__cta-button { display: inline-flex; align-items: center; justify-content: center; margin-top: 32px; padding: 13px 22px; border-radius: 999px; color: #fff; background: #03cadf; font-size: 16px; font-weight: 700; line-height: 1; text-decoration: none; transition: transform .2s ease, background-color .2s ease; }
  .story-page--{{ section.id }} .story-page__cta-button:hover { color: #fff; background: #00b8cc; transform: translateY(-2px); }
  @media screen and (max-width: 749px) {
    .story-page--{{ section.id }} .story-page__container { width: calc(100% - 24px); }
    .story-page--{{ section.id }} .story-page__hero { min-height: 812px; }
    .story-page--{{ section.id }} .story-page__hero > .story-page__media { object-position: center; }
    .story-page--{{ section.id }} .story-page__hero-title { font-size: 36px; line-height: 1.3; }
    .story-page--{{ section.id }} .story-page__intro { padding: 60px 0; }
    .story-page--{{ section.id }} .story-page__intro-grid { grid-template-columns: 1fr; gap: 36px; }
    .story-page--{{ section.id }} .story-page__intro-copy h2, .story-page--{{ section.id }} .story-page__technology-heading { font-size: 36px; }
    .story-page--{{ section.id }} .story-page__rte { margin-top: 28px; font-size: 14px; line-height: 1.45; }
    .story-page--{{ section.id }} .story-page__intro-image { min-height: 240px; border-radius: 12px; }
    .story-page--{{ section.id }} .story-page__mission { padding: 60px 0; }
    .story-page--{{ section.id }} .story-page__mission-grid { grid-template-columns: 1fr; gap: 40px; }
    .story-page--{{ section.id }} .story-page__mission-item { gap: 20px; }
    .story-page--{{ section.id }} .story-page__mission-item--future { flex-direction: column; }
    .story-page--{{ section.id }} .story-page__mission-item .story-page__rounded-image { height: 219px; border-radius: 12px; }
    .story-page--{{ section.id }} .story-page__mission-copy h2 { margin: 15px 0 20px; font-size: 36px; }
    .story-page--{{ section.id }} .story-page__mission-copy > p:last-child { font-size: 16px; line-height: 1.45; }
    .story-page--{{ section.id }} .story-page__technology { padding: 60px 0; }
    .story-page--{{ section.id }} .story-page__technology-heading { margin: 18px 0 22px; }
    .story-page--{{ section.id }} .story-page__feature-grid { grid-template-columns: 1fr; gap: 20px; }
    .story-page--{{ section.id }} .story-page__feature-card { min-height: 156px; border-radius: 12px; }
    .story-page--{{ section.id }} .story-page__feature-content { right: 12px; bottom: 12px; left: 12px; }
    .story-page--{{ section.id }} .story-page__feature-content h3 { font-size: 24px; }
    .story-page--{{ section.id }} .story-page__feature-content p { margin-top: 10px; font-size: 14px; line-height: 1.4; }
    .story-page--{{ section.id }} .story-page__video { aspect-ratio: 375 / 211; }
    .story-page--{{ section.id }} .story-page__cta { min-height: 660px; align-items: flex-start; padding-top: 69px; }
    .story-page--{{ section.id }} .story-page__cta-content h2 { font-size: 36px; line-height: 1.2; }
    .story-page--{{ section.id }} .story-page__cta-content p { margin-top: 18px; font-size: 14px; line-height: 1.4; }
    .story-page--{{ section.id }} .story-page__cta-button { margin-top: 22px; padding: 10px 14px; }
  }
{% endstyle %}

{% style %}
  /* Figma type ramp and fixed composition for the 1920px desktop / 375px mobile designs. */
  .story-page--{{ section.id }} { font-family: "Inter", Arial, sans-serif; }
  .story-page--{{ section.id }} .story-page__technology-heading-mobile { display: none; }
  .story-page--{{ section.id }} .story-page__hero-title { font-family: "Inter", Arial, sans-serif; font-weight: 900; letter-spacing: 0; }
  .story-page--{{ section.id }} .story-page__intro-copy h2,
  .story-page--{{ section.id }} .story-page__mission-copy h2,
  .story-page--{{ section.id }} .story-page__technology-heading,
  .story-page--{{ section.id }} .story-page__feature-content h3,
  .story-page--{{ section.id }} .story-page__cta-content h2 { font-family: "Inter", Arial, sans-serif; font-weight: 700; letter-spacing: 0; }
  .story-page--{{ section.id }} .story-page__rte,
  .story-page--{{ section.id }} .story-page__mission-copy > p:last-child,
  .story-page--{{ section.id }} .story-page__cta-content p { font-family: "Inter", Arial, sans-serif; font-weight: 500; }
  .story-page--{{ section.id }} .story-page__eyebrow { font-family: "Inter", Arial, sans-serif; font-weight: 700; letter-spacing: 0; }

  @media screen and (min-width: 750px) {
    .story-page--{{ section.id }} .story-page__container { width: min(calc(100% - 48px), 1440px); }
    .story-page--{{ section.id }} .story-page__hero { min-height: 0; aspect-ratio: 16 / 9; max-height: none; display: block; }
    .story-page--{{ section.id }} .story-page__hero-title { position: absolute; top: 50%; left: max(24px, calc(50% - 431px)); transform: translateY(-50%); padding: 0; font-size: 80px; line-height: 1.3; text-align: left; white-space: nowrap; }

    .story-page--{{ section.id }} .story-page__intro { height: 920px; padding: 0; }
    .story-page--{{ section.id }} .story-page__intro-grid { position: relative; display: block; height: 100%; }
    .story-page--{{ section.id }} .story-page__intro-copy { position: absolute; top: 221px; left: 0; width: min(61.81%, 890px); }
    .story-page--{{ section.id }} .story-page__intro-copy h2 { font-size: 72px; line-height: 76px; }
    .story-page--{{ section.id }} .story-page__rte { margin-top: 32px; font-size: 20px; line-height: 1.45; }
    .story-page--{{ section.id }} .story-page__rte p + p { margin-top: 20px; }
    .story-page--{{ section.id }} .story-page__intro-image { position: absolute; top: 100px; right: 0; width: min(31.94%, 460px); min-height: 720px; height: 720px; border-radius: 24px; }

    .story-page--{{ section.id }} .story-page__mission { height: 1289px; padding: 0; }
    .story-page--{{ section.id }} .story-page__mission-grid { display: block; height: 100%; }
    .story-page--{{ section.id }} .story-page__mission-item { display: contents; }
    .story-page--{{ section.id }} .story-page__mission-item .story-page__rounded-image { position: absolute; width: min(55.56%, 800px); height: 500px; margin: 0; border-radius: 24px; }
    .story-page--{{ section.id }} .story-page__mission-item:first-child .story-page__rounded-image { top: 100px; left: 0; }
    .story-page--{{ section.id }} .story-page__mission-item--future .story-page__rounded-image { top: 680px; right: 0; }
    .story-page--{{ section.id }} .story-page__mission-copy { position: absolute; width: min(37.15%, 535px); }
    .story-page--{{ section.id }} .story-page__mission-item:first-child .story-page__mission-copy { top: 209px; right: 0; }
    .story-page--{{ section.id }} .story-page__mission-item--future .story-page__mission-copy { top: 811px; left: 0; width: min(36.81%, 530px); }
    .story-page--{{ section.id }} .story-page__eyebrow { font-size: 14px; line-height: 15px; }
    .story-page--{{ section.id }} .story-page__mission-copy h2 { margin: 12px 0 16px; font-size: 72px; line-height: 76px; }
    .story-page--{{ section.id }} .story-page__mission-copy > p:last-child { font-size: 20px; line-height: 1.45; }
    .story-page--{{ section.id }} .story-page__mission-item--future .story-page__mission-copy h2 { margin-top: 18px; margin-bottom: 28px; }

    .story-page--{{ section.id }} .story-page__technology { height: 1082px; padding: 0; }
    .story-page--{{ section.id }} .story-page__technology > .story-page__container { position: relative; height: 100%; }
    .story-page--{{ section.id }} .story-page__technology > .story-page__container > .story-page__eyebrow { position: absolute; top: 100px; left: 0; }
    .story-page--{{ section.id }} .story-page__technology-heading { position: absolute; top: 135px; left: 0; margin: 0; font-size: 72px; line-height: 76px; }
    .story-page--{{ section.id }} .story-page__feature-grid { position: absolute; top: 367px; right: 0; left: 0; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 55px 60px; }
    .story-page--{{ section.id }} .story-page__feature-card { min-height: 280px; height: 280px; border-radius: 28px; }
    .story-page--{{ section.id }} .story-page__feature-content { top: 157px; right: auto; bottom: auto; left: 20px; width: 360px; }
    .story-page--{{ section.id }} .story-page__feature-content h3 { font-size: 24px; line-height: 37px; }
    .story-page--{{ section.id }} .story-page__feature-content p { width: 350px; margin-top: 12px; font-size: 16px; font-weight: 700; line-height: 27px; }
    .story-page--{{ section.id }} .story-page__feature-card:nth-child(4) .story-page__feature-content { top: 130px; }

    .story-page--{{ section.id }} .story-page__video { aspect-ratio: 16 / 9; background: #fff; }
    .story-page--{{ section.id }} .story-page__cta { min-height: 640px; height: 640px; align-items: flex-start; padding: 0; }
    .story-page--{{ section.id }} .story-page__cta-content { position: relative; padding-top: 216px; }
    .story-page--{{ section.id }} .story-page__cta-content h2 { font-size: 68px; line-height: 1; white-space: nowrap; }
    .story-page--{{ section.id }} .story-page__cta-content p { margin-top: 25px; max-width: 731px; font-size: 20px; line-height: 1.45; }
    .story-page--{{ section.id }} .story-page__cta-button { height: 50px; margin-top: 26px; padding: 2px 28px; font-size: 24px; font-weight: 600; }
  }

  @media screen and (max-width: 749px) {
    .story-page--{{ section.id }} .story-page__container { width: calc(100% - 24px); }
    .story-page--{{ section.id }} .story-page__hero { min-height: 812px; aspect-ratio: auto; }
    .story-page--{{ section.id }} .story-page__hero-title { padding: 0 12px; font-size: 36px; font-weight: 900; line-height: 1.3; }

    .story-page--{{ section.id }} .story-page__intro { height: 812px; padding: 0; }
    .story-page--{{ section.id }} .story-page__intro-grid { position: relative; display: block; height: 100%; }
    .story-page--{{ section.id }} .story-page__intro-copy { position: absolute; top: 60px; left: 0; width: 100%; }
    .story-page--{{ section.id }} .story-page__intro-copy h2 { font-size: 36px; line-height: 36px; }
    .story-page--{{ section.id }} .story-page__rte { margin-top: 20px; font-size: 14px; line-height: 1.45; }
