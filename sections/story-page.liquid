    .story-page--{{ section.id }} .story-page__anchor-copy > p:last-child { font-size: 16px; line-height: 1.45; }

    .story-page--{{ section.id }} .story-page__mission { min-height: 623px; padding: 60px 0; }
    .story-page--{{ section.id }} .story-page__mission-grid { display: grid; height: auto; grid-template-columns: 1fr; gap: 20px; }
    .story-page--{{ section.id }} .story-page__mission-item { display: contents; }
    .story-page--{{ section.id }} .story-page__mission-item .story-page__rounded-image { position: static; width: 100%; height: 220px; margin: 0; }
    .story-page--{{ section.id }} .story-page__mission-copy,
    .story-page--{{ section.id }} .story-page__mission-item--future .story-page__mission-copy { width: auto; }
    .story-page--{{ section.id }} .story-page__mission-copy h2 { margin: 8px 0 14px; font-size: 24px; line-height: 1; }
    .story-page--{{ section.id }} .story-page__mission-copy > p:last-child { font-size: 16px; line-height: 1.45; }
    .story-page--{{ section.id }} .story-page__mission-item--future .story-page__mission-copy h2 { margin: 8px 0 26px; }

    .story-page--{{ section.id }} .story-page__technology { min-height: 1793px; padding: 60px 0; }
    .story-page--{{ section.id }} .story-page__technology > .story-page__container { height: auto; }
    .story-page--{{ section.id }} .story-page__technology > .story-page__container > .story-page__eyebrow { position: static; }
    .story-page--{{ section.id }} .story-page__technology-heading { margin: 8px 0 40px; font-size: 36px; line-height: 36px; }
    .story-page--{{ section.id }} .story-page__feature-grid { display: grid; grid-template-columns: 1fr; grid-template-rows: 381px 381px 396px 376px; gap: 20px; }
    .story-page--{{ section.id }} .story-page__feature-card { height: auto; }
    .story-page--{{ section.id }} .story-page__feature-image { height: 280px; }
    .story-page--{{ section.id }} .story-page__feature-card:nth-child(2) .story-page__feature-image { height: 285px; }
    .story-page--{{ section.id }} .story-page__feature-card:nth-child(4) { margin-top: -20px; }
    .story-page--{{ section.id }} .story-page__feature-content { margin-top: 20px; }
    .story-page--{{ section.id }} .story-page__feature-content h3 { font-size: 24px; line-height: 24px; }
    .story-page--{{ section.id }} .story-page__feature-content p { margin-top: 12px; font-size: 14px; font-weight: 500; line-height: 1.4; }

    .story-page--{{ section.id }} .story-page__cta { display: block; height: 660px; min-height: 660px; padding: 60px 0 0; }
    .story-page--{{ section.id }} .story-page__cta-content { padding: 0; }
