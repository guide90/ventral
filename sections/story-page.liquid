    .story-page--{{ section.id }} .story-page__cta-content p { max-width: 351px; margin-top: 20px; font-size: 14px; line-height: 1.4; }
    .story-page--{{ section.id }} .story-page__cta-button { margin-top: 20px; padding: 8px 14px; font-size: 16px; }
