{%- liquid
  assign pc_image = section.settings.pc_image
  assign mobile_image = section.settings.mobile_image
  assign heading = section.settings.heading | escape | replace: '&amp;', '<em>&</em>'
-%}

<div
  class="index-carry-feature"
  style="--index-carry-feature-bg: {{ section.settings.background_color }}; --index-carry-feature-text: {{ section.settings.text_color }}; --index-carry-feature-accent: {{ section.settings.accent_color }}; --index-carry-feature-page-width: {{ section.settings.page_width }}px; --index-carry-feature-image-width: {{ section.settings.image_width }}px; --index-carry-feature-radius: {{ section.settings.border_radius }}px; --index-carry-feature-padding-top: {{ section.settings.padding_top }}px; --index-carry-feature-padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="index-carry-feature__inner">
    <div class="index-carry-feature__content">
      {%- if section.settings.badge != blank -%}
        <div class="index-carry-feature__badge">{{ section.settings.badge | escape }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="index-carry-feature__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="index-carry-feature__text">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>

    <div class="index-carry-feature__media">
      {%- if pc_image != blank or mobile_image != blank -%}
        <picture class="index-carry-feature__picture">
          {%- if mobile_image != blank -%}
            <source
              media="(max-width: 767px)"
              srcset="{{ mobile_image | image_url: width: 550 }} 550w, {{ mobile_image | image_url: width: 750 }} 750w, {{ mobile_image | image_url: width: 1100 }} 1100w"
              sizes="100vw">
          {%- endif -%}

          {%- if pc_image != blank -%}
            {{
              pc_image
              | image_url: width: 1600
              | image_tag:
                class: 'index-carry-feature__image',
                loading: 'lazy',
                widths: '750, 1100, 1400, 1600',
                sizes: '(max-width: 767px) 100vw, 920px',
                alt: section.settings.heading
            }}
          {%- else -%}
            {{
              mobile_image
              | image_url: width: 1100
              | image_tag:
                class: 'index-carry-feature__image',
                loading: 'lazy',
                widths: '375, 550, 750, 1100',
                sizes: '100vw',
                alt: section.settings.heading
            }}
          {%- endif -%}
        </picture>
      {%- else -%}
        <div class="index-carry-feature__placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Index carry feature",
  "tag": "section",
  "class": "index-carry-feature-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "pc_image",
      "label": "PC image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "BUILT FOR EFFORTLESS ADVENTURES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lightweight & Easy to Carry"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Designed for effortless transport, so one person can carry the essentials with ease.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#1d9bd7"
    },
    {
      "type": "range",
      "id": "page_width",
      "label": "Page width",
      "default": 1100,
      "min": 760,
      "max": 1600,
      "step": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "default": 920,
      "min": 560,
      "max": 1300,
      "step": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image border radius",
      "default": 12,
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop top padding",
      "default": 84,
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop bottom padding",
      "default": 92,
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Index carry feature"
    }
  ]
}
{% endschema %}
