{%- liquid
  assign community_font = section.settings.community_font
  assign community_font_medium = community_font | font_modify: 'weight', '500'
  assign community_font_semibold = community_font | font_modify: 'weight', '600'
  assign community_font_bold = community_font | font_modify: 'weight', '700'
-%}

{% style %}
  {{ community_font | font_face: font_display: 'swap' }}
  {{ community_font_medium | font_face: font_display: 'swap' }}
  {{ community_font_semibold | font_face: font_display: 'swap' }}
  {{ community_font_bold | font_face: font_display: 'swap' }}

  #community-{{ section.id }} {
    color: #06142e;
    font-family: {{ community_font.family }}, {{ community_font.fallback_families }};
    overflow: hidden;
  }

  #community-{{ section.id }} *,
  #community-{{ section.id }} *::before,
  #community-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #community-{{ section.id }} h1,
  #community-{{ section.id }} h2,
  #community-{{ section.id }} p {
    margin: 0;
  }

  #community-{{ section.id }} .community-shell {
    width: min(1440px, calc(100% - 48px));
    margin: 0 auto;
  }

  #community-{{ section.id }} .community-placeholder {
    display: block;
    width: 100%;
    height: 100%;
    background: #738798;
    fill: #a9c4d7;
  }

  #community-{{ section.id }} .community-hero {
    position: relative;
    height: min(56.25vw, 1080px);
    min-height: 720px;
    overflow: hidden;
    color: #ffffff;
    background: #60768a;
  }

  #community-{{ section.id }} .community-hero__media,
  #community-{{ section.id }} .community-hero__picture,
  #community-{{ section.id }} .community-hero__image,
  #community-{{ section.id }} .community-hero__shade {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  #community-{{ section.id }} .community-hero__image {
    object-fit: cover;
    object-position: center;
  }

  #community-{{ section.id }} .community-hero__shade {
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0) 10.573%,
      rgba(0, 0, 0, 0.5) 100%
    );
  }

  #community-{{ section.id }} .community-hero__content {
    position: absolute;
    top: 40%;
    left: calc(50% + 64px);
    display: flex;
    width: 656px;
    max-width: calc(50% - 88px);
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  #community-{{ section.id }} .community-hero__title {
    color: #ffffff;
    font-size: 64px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
  }

  #community-{{ section.id }} .community-hero__copy {
    width: 600px;
    max-width: 100%;
    color: #ffffff;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.45;
  }

  #community-{{ section.id }} .community-hero__button {
    display: inline-flex;
    min-height: 50px;
    padding: 2px 28px;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    color: #0c284c;
    background: #ffffff;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.2;
    text-decoration: none;
    cursor: pointer;
  }

  #community-{{ section.id }} .community-stories {
    height: 1279px;
    padding-top: 104px;
    color: #ffffff;
    background: #0c0e12;
  }

  #community-{{ section.id }} .community-section-title {
    font-size: 54px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
    text-align: center;
  }

  #community-{{ section.id }} .community-stories__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-top: 56px;
  }

  #community-{{ section.id }} .community-story {
    position: relative;
    min-width: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 24px;
    background: #1c2734;
  }

  #community-{{ section.id }} .community-story__media {
    position: absolute;
    inset: 0;
  }

  #community-{{ section.id }} .community-story__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #community-{{ section.id }} .community-story__media::after {
    position: absolute;
    inset: auto 0 0;
    height: 61px;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
    content: "";
  }

  #community-{{ section.id }} .community-story__caption {
    position: absolute;
    right: 20px;
    bottom: 16px;
    left: 20px;
    z-index: 1;
    color: #ffffff;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.45;
  }

  #community-{{ section.id }} .community-videos {
    height: 840px;
    padding-top: 100px;
    background: #ffffff;
  }

  #community-{{ section.id }} .community-videos__layout {
    position: relative;
    width: 968px;
    height: 640px;
    margin: 0 auto;
  }

  #community-{{ section.id }} .community-videos__intro {
    position: absolute;
    top: 130px;
    left: 0;
    width: 428px;
    text-align: left;
  }

  #community-{{ section.id }} .community-videos__eyebrow {
    color: #3983fb;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 15px;
  }

  #community-{{ section.id }} .community-videos__title {
    margin-top: 12px;
    color: #06142e;
    font-size: 54px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
  }

  #community-{{ section.id }} .community-videos__copy {
    margin-top: 26px;
    color: #a5a9b7;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.45;
  }

  #community-{{ section.id }} .community-videos__player {
    position: absolute;
    top: 0;
    right: 0;
    width: 360px;
    height: 640px;
    overflow: hidden;
    border-radius: 24px;
    background: #0c0e12;
  }

  #community-{{ section.id }} .community-videos__media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
  }

  #community-{{ section.id }} .community-videos__play {
    position: absolute;
    top: 50%;
    left: 50%;
    display: block;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 0;
    color: #ffffff;
    background: transparent;
    transform: translate(-50%, -50%);
    cursor: pointer;
  }

  #community-{{ section.id }} .community-videos__play[hidden] {
    display: none;
  }

  #community-{{ section.id }} .community-videos__play svg {
    display: block;
    width: 40px;
    height: 40px;
  }

  #community-{{ section.id }} .community-videos__list {
    position: absolute;
    top: 358px;
    left: 0;
    display: flex;
    width: 428px;
    max-height: 182px;
    flex-direction: column;
    gap: 8px;
    overflow-x: hidden;
    overflow-y: auto;
  }

  #community-{{ section.id }} .community-videos__carousel {
    display: none;
  }

  #community-{{ section.id }} .community-video-card {
    position: relative;
    display: flex;
    width: 100%;
    min-height: 60px;
    align-items: center;
    gap: 8px;
    padding: 0;
    border: 0;
    color: #06142e;
    background: transparent;
    font-family: inherit;
    text-align: left;
    cursor: pointer;
  }

  #community-{{ section.id }} .community-video-card::before {
    width: 6px;
    height: 59px;
    flex: 0 0 auto;
    border-radius: 100px;
    background: transparent;
    content: "";
  }

  #community-{{ section.id }} .community-video-card.is-active::before {
    background: #3983fb;
  }

  #community-{{ section.id }} .community-video-card__thumb {
    width: 60px;
    height: 60px;
    margin-left: 6px;
    flex: 0 0 auto;
    overflow: hidden;
    border-radius: 12px;
    background: #d4e3e5;
  }

  #community-{{ section.id }} .community-video-card__thumb img,
  #community-{{ section.id }} .community-video-card__thumb svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #community-{{ section.id }} .community-video-card__details {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 4px;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
  }

  #community-{{ section.id }} .community-video-card__number {
    color: #3983fb;
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
  }

  #community-{{ section.id }} .community-video-card__title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #community-{{ section.id }} .community-connect {
    height: 935px;
    padding-top: 100px;
    color: #000000;
    background: #f1f1f1;
  }

  #community-{{ section.id }} .community-connect__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
    margin-top: 60px;
  }

  #community-{{ section.id }} .community-connect__card {
    position: relative;
    min-width: 0;
    height: 610px;
    overflow: hidden;
    border-radius: 24px;
    color: #ffffff;
    background: #5b6570;
  }

  #community-{{ section.id }} .community-connect__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #community-{{ section.id }} .community-connect__gradient {
    position: absolute;
    inset: auto 0 0;
    height: 104px;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  #community-{{ section.id }} .community-connect__content {
    position: absolute;
    right: 20px;
    bottom: 20px;
    left: 20px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    color: #ffffff;
  }

  #community-{{ section.id }} .community-connect__title {
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1;
  }

  #community-{{ section.id }} .community-connect__meta {
    display: flex;
    min-height: 18px;
    align-items: center;
    gap: 8px;
    color: #ffffff;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.3;
  }

  #community-{{ section.id }} .community-connect__social {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 4px;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  #community-{{ section.id }} .community-connect__email {
    text-decoration: none;
    cursor: pointer;
  }

  #community-{{ section.id }} .community-connect__social-label,
  #community-{{ section.id }} .community-connect__group > span {
    white-space: nowrap;
  }

  #community-{{ section.id }} .community-connect__icon {
    display: block;
    width: 24px;
    height: 24px;
    flex: 0 0 auto;
    color: #ffffff;
  }

  #community-{{ section.id }} .community-connect__icon--email {
    width: 18px;
    height: 18px;
  }

  #community-{{ section.id }} .community-connect__group {
    display: inline-flex;
    width: fit-content;
    min-height: 26px;
    padding: 4px 12px;
    align-items: center;
    gap: 12px;
    border-radius: 12px;
    color: #ffffff;
    background: #0c284c;
    text-decoration: none;
    cursor: pointer;
  }

  #community-{{ section.id }} .community-connect__arrow {
    display: none;
    width: 26px;
    height: 8px;
    color: #ffffff;
  }

  @media (min-width: 750px) and (max-width: 1279px) {
    #community-{{ section.id }} .community-hero__content {
      left: 54%;
      width: 42%;
      max-width: 42%;
    }

    #community-{{ section.id }} .community-hero__title {
      font-size: 48px;
    }

    #community-{{ section.id }} .community-videos__layout {
      width: min(968px, calc(100% - 48px));
    }

    #community-{{ section.id }} .community-videos__intro,
    #community-{{ section.id }} .community-videos__list {
      width: calc(100% - 500px);
    }
  }

  @media (max-width: 749px) {
    #community-{{ section.id }} .community-shell {
      width: calc(100% - 22px);
    }

    #community-{{ section.id }} .community-hero {
      height: 812px;
      min-height: 0;
    }

    #community-{{ section.id }} .community-hero__image {
      object-position: center top;
    }

    #community-{{ section.id }} .community-hero__shade {
      height: 371px;
      background: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.4) 63.025%,
        rgba(0, 0, 0, 0) 99.932%
      );
    }

    #community-{{ section.id }} .community-hero__content {
      top: 145px;
      right: 12px;
      left: 12px;
      width: auto;
      max-width: none;
      align-items: center;
      gap: 8px;
      text-align: center;
    }

    #community-{{ section.id }} .community-hero__title {
      font-size: 32px;
      line-height: 1.2;
    }

    #community-{{ section.id }} .community-hero__copy {
      width: 351px;
      font-size: 14px;
      font-weight: 400;
      line-height: 1.45;
    }

    #community-{{ section.id }} .community-hero__button {
      min-width: 180px;
      min-height: 35px;
      padding: 8px 14px;
      color: #ffffff;
      background: #0c284c;
      font-size: 16px;
      font-weight: 600;
    }

    #community-{{ section.id }} .community-stories {
      height: 790px;
      padding-top: 40px;
    }

    #community-{{ section.id }} .community-section-title {
      font-size: 32px;
      line-height: 1.2;
    }

    #community-{{ section.id }} .community-stories__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 11px;
      row-gap: 20px;
      margin-top: 26px;
    }

    #community-{{ section.id }} .community-story {
      aspect-ratio: auto;
      overflow: visible;
      border-radius: 0;
      background: transparent;
    }

    #community-{{ section.id }} .community-story__media {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 12px;
      background: #1c2734;
    }

    #community-{{ section.id }} .community-story__media::after {
      display: none;
    }

    #community-{{ section.id }} .community-story__caption {
      position: static;
      margin-top: 12px;
      color: #ffffff;
      font-size: 14px;
      font-weight: 500;
      line-height: 1.45;
    }

    #community-{{ section.id }} .community-videos {
      height: 937px;
      padding-top: 0;
    }

    #community-{{ section.id }} .community-videos__layout {
      width: 100%;
      height: 937px;
    }

    #community-{{ section.id }} .community-videos__intro {
      top: 40px;
      right: 12px;
      left: 12px;
      width: auto;
      text-align: left;
    }

    #community-{{ section.id }} .community-videos__eyebrow {
      font-size: 14px;
      line-height: 15px;
    }

    #community-{{ section.id }} .community-videos__title {
      margin-top: 8px;
      font-size: 24px;
      line-height: 1.2;
    }

    #community-{{ section.id }} .community-videos__copy {
      margin-top: 18px;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.45;
    }

    #community-{{ section.id }} .community-videos__player {
      display: none;
    }

    #community-{{ section.id }} .community-videos__list {
      display: none;
    }

    #community-{{ section.id }} .community-videos__carousel {
      position: absolute;
      top: 193px;
      display: flex;
      width: 100%;
      height: 704px;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    #community-{{ section.id }} .community-videos__carousel::-webkit-scrollbar {
      display: none;
    }

    #community-{{ section.id }} .community-video-slide {
      display: flex;
      width: 100%;
      min-width: 100%;
      padding: 0 8px;
      flex-direction: column;
      gap: 20px;
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }

    #community-{{ section.id }} .community-video-slide__player {
      position: relative;
      width: 100%;
      height: 624px;
      flex: 0 0 auto;
      overflow: hidden;
      border-radius: 12px;
      background: #0c0e12;
    }

    #community-{{ section.id }} .community-video-slide .community-video-card {
      width: 100%;
      min-height: 60px;
      flex: 0 0 60px;
      cursor: default;
    }

    #community-{{ section.id }} .community-connect {
      height: 810px;
      padding-top: 40px;
    }

    #community-{{ section.id }} .community-connect .community-section-title {
      width: 351px;
      margin: 0 auto;
    }

    #community-{{ section.id }} .community-connect__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 11px;
      row-gap: 12px;
      margin-top: 39px;
    }

    #community-{{ section.id }} .community-connect__card {
      height: 301px;
      border-radius: 12px;
    }

    #community-{{ section.id }} .community-connect__gradient {
      height: 116px;
    }

    #community-{{ section.id }} .community-connect__content {
      right: 12px;
      bottom: 12px;
      left: 12px;
      gap: 8px;
    }

    #community-{{ section.id }} .community-connect__title {
      font-size: 20px;
      line-height: 1.2;
    }

    #community-{{ section.id }} .community-connect__meta {
      min-height: 18px;
      gap: 4px;
      font-size: 14px;
      font-weight: 400;
      line-height: 1.3;
    }

    #community-{{ section.id }} .community-connect__social {
      gap: 0;
    }

    #community-{{ section.id }} .community-connect__social + .community-connect__social {
      margin-left: 4px;
    }

    #community-{{ section.id }} .community-connect__social-label {
      display: none;
    }

    #community-{{ section.id }} .community-connect__icon {
      width: 16px;
      height: 16px;
    }

    #community-{{ section.id }} .community-connect__icon--email {
      width: 16px;
      height: 16px;
      margin-right: 2px;
      margin-left: 2px;
    }

    #community-{{ section.id }} .community-connect__group {
      width: 146px;
      min-height: 18px;
      padding: 0;
      gap: 12px;
      border-radius: 0;
      background: transparent;
    }

    #community-{{ section.id }} .community-connect__arrow {
      display: block;
      width: 26px;
      height: 6px;
      flex: 0 0 26px;
    }
  }
{% endstyle %}

{%- assign first_video = section.blocks | where: 'type', 'video' | first -%}
{%- assign first_video_poster = first_video.settings.poster | default: first_video.settings.video.preview_image -%}
{%- assign first_video_source = first_video.settings.video.sources | where: 'format', 'mp4' | first -%}
{%- if first_video_source == blank -%}
  {%- assign first_video_source = first_video.settings.video.sources | first -%}
{%- endif -%}

<section class="community-page" id="community-{{ section.id }}">
  <div class="community-hero">
    <div class="community-hero__media">
      {%- if section.settings.hero_image != blank -%}
        <picture class="community-hero__picture">
          {%- if section.settings.hero_image_mobile != blank -%}
            <source
              media="(max-width: 749px)"
              srcset="
                {{ section.settings.hero_image_mobile | image_url: width: 750 }} 750w,
                {{ section.settings.hero_image_mobile | image_url: width: 1100 }} 1100w
              "
              sizes="100vw"
            >
          {%- endif -%}
          {{
            section.settings.hero_image
            | image_url: width: 2400
            | image_tag:
              class: 'community-hero__image',
              widths: '750, 1100, 1500, 1920, 2400',
              sizes: '100vw',
              preload: true,
              alt: section.settings.heading
          }}
        </picture>
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'community-placeholder' }}
      {%- endif -%}
    </div>
    <div class="community-hero__shade"></div>
    <div class="community-hero__content">
      <h1 class="community-hero__title">{{ section.settings.heading | escape }}</h1>
      <p class="community-hero__copy">{{ section.settings.subheading | escape }}</p>
      {%- if section.settings.button_label != blank -%}
        <a
          class="community-hero__button"
          href="{{ section.settings.button_link | default: 'https://www.facebook.com/share/g/1CoJoroYyV/' }}"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="community-stories">
    <div class="community-shell">
      <h2 class="community-section-title">{{ section.settings.stories_heading | escape }}</h2>
      <div class="community-stories__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'story' -%}
            <article class="community-story" {{ block.shopify_attributes }}>
              <div class="community-story__media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1000
                    | image_tag:
                      class: 'community-story__image',
                      widths: '375, 550, 750, 1000',
                      sizes: '(min-width: 750px) 31vw, 46vw',
                      loading: 'lazy',
                      alt: block.settings.title
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'community-placeholder' }}
                {%- endif -%}
              </div>
              <div class="community-story__caption">{{ block.settings.title | escape }}</div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="community-videos">
    <div class="community-videos__layout">
      <div class="community-videos__intro">
        <p class="community-videos__eyebrow">{{ section.settings.video_eyebrow | escape }}</p>
        <h2 class="community-videos__title">{{ section.settings.videos_heading | escape }}</h2>
        <p class="community-videos__copy">{{ section.settings.videos_copy | escape }}</p>
      </div>

      <div class="community-videos__player" data-community-video-player>
        <video
          class="community-videos__media"
          data-community-video-media
          preload="metadata"
          playsinline
          tabindex="0"
          role="button"
          aria-label="Play {{ first_video.settings.title | default: 'featured video' | escape }}"
          {% if first_video_poster != blank %}
            poster="{{ first_video_poster | image_url: width: 1000 }}"
          {% endif %}
        >
          {%- if first_video_source != blank -%}
            <source
              data-community-video-source
              src="{{ first_video_source.url }}"
              type="{{ first_video_source.mime_type }}"
            >
          {%- else -%}
            <source data-community-video-source>
          {%- endif -%}
        </video>
        <button
          class="community-videos__play"
          type="button"
          data-community-video-play
          aria-label="Play {{ first_video.settings.title | default: 'featured video' | escape }}"
          {% if first_video_source == blank %}
            hidden
          {% endif %}
        >
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="40" height="40" rx="20" fill="black" fill-opacity="0.38"/>
            <path d="M25.4599 17.8096C27.1374 18.7881 27.1374 21.2119 25.4599 22.1904L17.8136 26.6508C16.1231 27.6369 14 26.4175 14 24.4604V15.5396C14 13.5825 16.1231 12.3631 17.8136 13.3492L25.4599 17.8096Z" fill="white"/>
          </svg>
        </button>
      </div>

      <div class="community-videos__list">
        {%- assign video_number = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'video' -%}
            {%- assign video_number = video_number | plus: 1 -%}
            {%- assign video_card_poster = block.settings.poster | default: block.settings.video.preview_image -%}
            {%- assign video_card_source = block.settings.video.sources | where: 'format', 'mp4' | first -%}
            {%- if video_card_source == blank -%}
              {%- assign video_card_source = block.settings.video.sources | first -%}
            {%- endif -%}
            <button
              class="community-video-card{% if video_number == 1 %} is-active{% endif %}"
              type="button"
              data-community-video-card
              data-video-src="{{ video_card_source.url | escape }}"
              data-video-type="{{ video_card_source.mime_type | escape }}"
              data-video-poster="{% if video_card_poster != blank %}{{ video_card_poster | image_url: width: 1000 }}{% endif %}"
              data-video-title="{{ block.settings.title | default: 'Sunrise Paddle' | escape }}"
              aria-pressed="{% if video_number == 1 %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="community-video-card__thumb">
                {%- if video_card_poster != blank -%}
                  {{
                    video_card_poster
                    | image_url: width: 180
                    | image_tag: widths: '120, 180', sizes: '60px', loading: 'lazy', alt: ''
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'community-placeholder' }}
                {%- endif -%}
              </div>
              <div class="community-video-card__details">
                <span class="community-video-card__number">
                  {{- video_number | prepend: '0' | slice: -2, 2 -}}
                </span>
                <span class="community-video-card__title">
                  {{- block.settings.title | default: 'Sunrise Paddle' | escape -}}
                </span>
              </div>
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="community-videos__carousel" data-community-mobile-video-carousel aria-label="Community videos">
        {%- assign mobile_video_number = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'video' -%}
            {%- assign mobile_video_number = mobile_video_number | plus: 1 -%}
            {%- assign mobile_video_poster = block.settings.poster | default: block.settings.video.preview_image -%}
            {%- assign mobile_video_source = block.settings.video.sources | where: 'format', 'mp4' | first -%}
            {%- if mobile_video_source == blank -%}
              {%- assign mobile_video_source = block.settings.video.sources | first -%}
            {%- endif -%}
            <article
              class="community-video-slide"
              data-community-mobile-video-slide
              aria-current="{% if mobile_video_number == 1 %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="community-video-slide__player">
                <video
                  class="community-videos__media"
                  data-community-mobile-video-media
                  preload="metadata"
                  playsinline
                  tabindex="0"
                  role="button"
                  aria-label="Play {{ block.settings.title | default: 'featured video' | escape }}"
                  {% if mobile_video_poster != blank %}
                    poster="{{ mobile_video_poster | image_url: width: 1000 }}"
                  {% endif %}
                >
                  {%- if mobile_video_source != blank -%}
                    <source src="{{ mobile_video_source.url }}" type="{{ mobile_video_source.mime_type }}">
                  {%- endif -%}
                </video>
                <button
                  class="community-videos__play"
                  type="button"
                  data-community-mobile-video-play
                  aria-label="Play {{ block.settings.title | default: 'featured video' | escape }}"
                  {% if mobile_video_source == blank %}
                    hidden
                  {% endif %}
                >
                  <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="40" height="40" rx="20" fill="black" fill-opacity="0.38"/>
                    <path d="M25.4599 17.8096C27.1374 18.7881 27.1374 21.2119 25.4599 22.1904L17.8136 26.6508C16.1231 27.6369 14 26.4175 14 24.4604V15.5396C14 13.5825 16.1231 12.3631 17.8136 13.3492L25.4599 17.8096Z" fill="white"/>
                  </svg>
                </button>
              </div>
              <div class="community-video-card{% if mobile_video_number == 1 %} is-active{% endif %}" data-community-mobile-video-card>
                <div class="community-video-card__thumb">
                  {%- if mobile_video_poster != blank -%}
                    {{
                      mobile_video_poster
                      | image_url: width: 180
                      | image_tag: widths: '120, 180', sizes: '60px', loading: 'lazy', alt: ''
                    }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'community-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="community-video-card__details">
                  <span class="community-video-card__number">
                    {{- mobile_video_number | prepend: '0' | slice: -2, 2 -}}
                  </span>
                  <span class="community-video-card__title">
                    {{- block.settings.title | default: 'Sunrise Paddle' | escape -}}
                  </span>
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

