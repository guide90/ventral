<script>
  (() => {
    const initializeCommunityVideo = (root) => {
      if (!root || root.dataset.communityVideoReady === 'true') {
        return;
      }

      const media = root.querySelector('[data-community-video-media]');
      const source = root.querySelector('[data-community-video-source]');
      const playButton = root.querySelector('[data-community-video-play]');
      const cards = Array.from(root.querySelectorAll('[data-community-video-card]'));
      const mobileCarousel = root.querySelector('[data-community-mobile-video-carousel]');
      const mobileSlides = mobileCarousel
        ? Array.from(mobileCarousel.querySelectorAll('[data-community-mobile-video-slide]'))
        : [];

      if (!media || !source || !playButton || cards.length === 0) {
        return;
      }

      root.dataset.communityVideoReady = 'true';

      const sourceAvailable = () => Boolean(source.getAttribute('src'));

      const updatePlayButton = () => {
        playButton.hidden = !sourceAvailable() || !media.paused;
      };

      const togglePlayback = () => {
        if (!sourceAvailable()) {
          return;
        }

        if (media.paused) {
          media.play().catch(() => {
            updatePlayButton();
          });
        } else {
          media.pause();
        }
      };

      const initializeMobilePlayer = (slide) => {
        const slideMedia = slide.querySelector('[data-community-mobile-video-media]');
        const slidePlayButton = slide.querySelector('[data-community-mobile-video-play]');
        const slideSource = slideMedia ? slideMedia.querySelector('source') : null;

        if (!slideMedia || !slidePlayButton || !slideSource || !slideSource.getAttribute('src')) {
          return;
        }

        const updateSlidePlayButton = () => {
          slidePlayButton.hidden = !slideMedia.paused;
        };

        const toggleSlidePlayback = () => {
          if (slideMedia.paused) {
            slideMedia.play().catch(updateSlidePlayButton);
          } else {
            slideMedia.pause();
          }
        };

        slidePlayButton.addEventListener('click', toggleSlidePlayback);
        slideMedia.addEventListener('click', toggleSlidePlayback);
        slideMedia.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            toggleSlidePlayback();
          }
        });
        slideMedia.addEventListener('play', updateSlidePlayButton);
        slideMedia.addEventListener('pause', updateSlidePlayButton);
        slideMedia.addEventListener('ended', updateSlidePlayButton);
        updateSlidePlayButton();
      };

      const selectVideo = (card) => {
        const videoUrl = card.dataset.videoSrc || '';
        const videoType = card.dataset.videoType || '';
        const videoPoster = card.dataset.videoPoster || '';
        const videoTitle = card.dataset.videoTitle || 'featured video';

        media.pause();

        if (videoPoster) {
          media.setAttribute('poster', videoPoster);
        } else {
          media.removeAttribute('poster');
        }

        if (videoUrl) {
          source.setAttribute('src', videoUrl);
        } else {
          source.removeAttribute('src');
        }

        if (videoType) {
          source.setAttribute('type', videoType);
        } else {
          source.removeAttribute('type');
        }

        media.setAttribute('aria-label', `Play ${videoTitle}`);
        playButton.setAttribute('aria-label', `Play ${videoTitle}`);
        media.load();

        cards.forEach((item) => {
          const isActive = item === card;
          item.classList.toggle('is-active', isActive);
          item.setAttribute('aria-pressed', String(isActive));
        });

        updatePlayButton();
      };

      cards.forEach((card) => {
        card.addEventListener('click', () => selectVideo(card));
      });

      mobileSlides.forEach(initializeMobilePlayer);

      if (mobileCarousel && mobileSlides.length) {
        const setMobileActiveSlide = (activeSlide) => {
          mobileSlides.forEach((slide) => {
            const isActive = slide === activeSlide;
            const card = slide.querySelector('[data-community-mobile-video-card]');
            const slideMedia = slide.querySelector('[data-community-mobile-video-media]');

            slide.setAttribute('aria-current', String(isActive));
            if (card) {
              card.classList.toggle('is-active', isActive);
            }
            if (!isActive && slideMedia && !slideMedia.paused) {
              slideMedia.pause();
            }
          });
        };

        const updateMobileActiveSlide = () => {
          const activeSlide = mobileSlides.reduce((closestSlide, slide) => {
            const slideDistance = Math.abs(slide.offsetLeft - mobileCarousel.scrollLeft);
            const closestDistance = Math.abs(closestSlide.offsetLeft - mobileCarousel.scrollLeft);

            return slideDistance < closestDistance ? slide : closestSlide;
          });

          setMobileActiveSlide(activeSlide);
        };

        let scrollFrame;
        mobileCarousel.addEventListener(
          'scroll',
          () => {
            window.cancelAnimationFrame(scrollFrame);
            scrollFrame = window.requestAnimationFrame(updateMobileActiveSlide);
          },
          { passive: true }
        );

        updateMobileActiveSlide();
      }

      playButton.addEventListener('click', togglePlayback);
      media.addEventListener('click', togglePlayback);
      media.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          togglePlayback();
        }
      });
      media.addEventListener('play', updatePlayButton);
      media.addEventListener('pause', updatePlayButton);
      media.addEventListener('ended', updatePlayButton);

      updatePlayButton();
    };

    const root = document.getElementById('community-{{ section.id }}');
    initializeCommunityVideo(root);

    if (!window.ventralCommunitySectionListener) {
      window.ventralCommunitySectionListener = true;
      document.addEventListener('shopify:section:load', (event) => {
        initializeCommunityVideo(event.target.querySelector('.community-page'));
      });
    }
  })();
</script>

