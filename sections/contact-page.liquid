{%- liquid
  assign contact_form_id = 'ContactPageForm-' | append: section.id
  assign contact_font = section.settings.contact_font
  assign contact_font_medium = contact_font | font_modify: 'weight', '500'
  assign contact_font_semibold = contact_font | font_modify: 'weight', '600'
  assign contact_font_bold = contact_font | font_modify: 'weight', '700'
  assign contact_font_black = contact_font | font_modify: 'weight', '900'
  assign contact_anchor = '#contact-form-' | append: section.id
  assign hero_button_link = section.settings.hero_button_link | default: contact_anchor
  assign perks_button_link = section.settings.perks_button_link | default: contact_anchor
  assign hero_image_desktop = section.settings.hero_image_desktop | default: section.settings.hero_image_mobile
  assign hero_image_mobile = section.settings.hero_image_mobile | default: hero_image_desktop
  assign perks_image_desktop = section.settings.perks_image_desktop | default: section.settings.perks_image_mobile
  assign perks_image_mobile = section.settings.perks_image_mobile | default: perks_image_desktop
-%}

{% style %}
  {{ contact_font | font_face: font_display: 'swap' }}
  {{ contact_font_medium | font_face: font_display: 'swap' }}
  {{ contact_font_semibold | font_face: font_display: 'swap' }}
  {{ contact_font_bold | font_face: font_display: 'swap' }}
  {{ contact_font_black | font_face: font_display: 'swap' }}

  body:has(#contact-page-{{ section.id }}) {
    overflow-x: clip;
  }

  body:has(#contact-page-{{ section.id }}) .main-content {
    width: 100%;
    max-width: none;
    margin: 0 !important;
    padding: 0 !important;
  }

  #contact-page-{{ section.id }} {
    --contact-navy: #06142e;
    --contact-button: #0c284c;
    --contact-muted: #a5a9b7;
    --contact-label: #62748e;
    --contact-field: #f8fafc;
    --contact-field-border: #e2e8f0;
    --contact-error: #ff5c61;
    width: 100vw;
    max-width: none;
    margin-left: 0;
    color: var(--contact-navy);
    font-family: {{ contact_font.family }}, {{ contact_font.fallback_families }};
    overflow: hidden;
  }

  #contact-page-{{ section.id }} *,
  #contact-page-{{ section.id }} *::before,
  #contact-page-{{ section.id }} *::after { box-sizing: border-box; }

  #contact-page-{{ section.id }} h1,
  #contact-page-{{ section.id }} h2,
  #contact-page-{{ section.id }} p { margin: 0; }

  #contact-page-{{ section.id }} button,
  #contact-page-{{ section.id }} input,
  #contact-page-{{ section.id }} textarea { font: inherit; }

  #contact-page-{{ section.id }} .contact-page__hero {
    position: relative;
    width: 100%;
    height: 1080px;
    overflow: hidden;
    background: #bababa;
    color: #fff;
  }

  #contact-page-{{ section.id }} .contact-page__hero-picture,
  #contact-page-{{ section.id }} .contact-page__hero-image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  #contact-page-{{ section.id }} .contact-page__hero-image {
    max-width: none;
    object-fit: cover;
  }

  #contact-page-{{ section.id }} .contact-page__hero-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,18,40,.18) 0%, rgba(0,18,40,0) 65%);
    pointer-events: none;
  }

  #contact-page-{{ section.id }} .contact-page__hero-content {
    position: absolute;
    z-index: 1;
    top: 404px;
    left: calc(50% - 720px);
    width: 800px;
  }

  #contact-page-{{ section.id }} .contact-page__hero-title {
    width: 800px;
    color: #fff;
    font-size: 80px;
    font-weight: 900;
    letter-spacing: -2px;
    line-height: 104px;
  }

  #contact-page-{{ section.id }} .contact-page__hero-copy {
    width: 600px;
    margin-top: -3px;
    color: #fff;
    font-size: 20px;
    font-weight: 500;
    line-height: 29px;
  }

  #contact-page-{{ section.id }} .contact-page__button {
    display: inline-flex;
    width: 283px;
    height: 50px;
    align-items: center;
    justify-content: center;
    padding: 0 28px;
    border: 0;
    border-radius: 100px;
    background: var(--contact-button);
    color: #fff;
    font-size: 24px;
    font-weight: 600;
    line-height: normal;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
  }

  #contact-page-{{ section.id }} .contact-page__hero-content .contact-page__button {
    margin-top: 20px;
    background: #fff;
    color: var(--contact-button);
  }

  #contact-page-{{ section.id }} .contact-page__perks {
    position: relative;
    width: 100%;
    height: 600px;
    overflow: hidden;
    background: #fafafa;
  }

  #contact-page-{{ section.id }} .contact-page__perks-copy {
    position: absolute;
    top: 161px;
    left: calc(50% - 720px);
    display: flex;
    width: 500px;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  #contact-page-{{ section.id }} .contact-page__perks-title {
    width: 500px;
    color: var(--contact-navy);
    font-size: 54px;
    font-weight: 700;
    letter-spacing: -1.08px;
    line-height: 64.8px;
  }

  #contact-page-{{ section.id }} .contact-page__perks-text {
    display: flex;
    width: 500px;
    min-height: 58px;
    align-items: center;
    color: var(--contact-muted);
    font-size: 20px;
    font-weight: 500;
    line-height: 29px;
  }

  #contact-page-{{ section.id }} .contact-page__perks-media {
    position: absolute;
    top: 100px;
    left: calc(50% - 120px);
    width: 840px;
    height: 400px;
    overflow: hidden;
    border-radius: 24px;
    background: #b76e6e;
  }

  #contact-page-{{ section.id }} .contact-page__perks-image--desktop,
  #contact-page-{{ section.id }} .contact-page__perks-image--mobile {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
  }

  #contact-page-{{ section.id }} .contact-page__perks-image--desktop { display: block; }
  #contact-page-{{ section.id }} .contact-page__perks-image--mobile { display: none; }

  #contact-page-{{ section.id }} .contact-page__form-section {
    position: relative;
    width: 100%;
    height: 867px;
    overflow: hidden;
    background: #fff;
  }

  #contact-page-{{ section.id }} .contact-page__form-heading {
    position: absolute;
    top: 100px;
    left: 50%;
    width: 1093px;
    transform: translateX(-50%);
    text-align: center;
  }

  #contact-page-{{ section.id }} .contact-page__form-title {
    height: 54px;
    color: var(--contact-navy);
    font-size: 54px;
    font-weight: 700;
    letter-spacing: -1.08px;
    line-height: 54px;
  }

  #contact-page-{{ section.id }} .contact-page__form-copy {
    margin-top: 20px;
    color: var(--contact-muted);
    font-size: 20px;
    font-weight: 500;
    line-height: 29px;
    white-space: nowrap;
  }

  #contact-page-{{ section.id }} .contact-page__form {
    position: absolute;
    inset: 0;
    width: 1090px;
    height: 867px;
    margin: 0 auto;
  }

  #contact-page-{{ section.id }} .contact-page__fields {
    position: absolute;
    top: 263px;
    left: 0;
    display: grid;
    width: 1090px;
    grid-template-columns: 535px 535px;
    grid-template-areas: "name phone" "email order" "message .";
    column-gap: 20px;
    row-gap: 24px;
  }

  #contact-page-{{ section.id }} .contact-field--name { grid-area: name; }
  #contact-page-{{ section.id }} .contact-field--email { grid-area: email; }
  #contact-page-{{ section.id }} .contact-field--message { grid-area: message; }
  #contact-page-{{ section.id }} .contact-field--phone { grid-area: phone; }
  #contact-page-{{ section.id }} .contact-field--order { grid-area: order; }

  #contact-page-{{ section.id }} .contact-field {
    width: 535px;
    height: 78px;
  }

  #contact-page-{{ section.id }} .contact-field__label {
    display: flex;
    width: 100%;
    height: 20px;
    align-items: center;
    gap: 8px;
    color: var(--contact-label);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -.1504px;
    line-height: 20px;
  }

  #contact-page-{{ section.id }} .contact-field__error-icon {
    display: none;
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
  }

  #contact-page-{{ section.id }} .contact-field.has-error .contact-field__label { color: var(--contact-error); }
  #contact-page-{{ section.id }} .contact-field.has-error .contact-field__error-icon { display: block; }

  #contact-page-{{ section.id }} .contact-field__control {
    display: block;
    width: 100%;
    height: 50px;
    margin-top: 8px;
    padding: 0 17px;
    border: 1px solid var(--contact-field-border);
    border-radius: 14px;
    outline: 0;
    background: var(--contact-field);
    color: var(--contact-navy);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -.3125px;
    line-height: 24px;
    box-shadow: none;
    appearance: none;
  }

  #contact-page-{{ section.id }} textarea.contact-field__control {
    min-height: 50px;
    padding-top: 12px;
    padding-bottom: 12px;
    resize: none;
  }

  #contact-page-{{ section.id }} .contact-field__control::placeholder {
    color: var(--contact-muted);
    opacity: 1;
  }

  #contact-page-{{ section.id }} .contact-field__control:focus {
    border-color: #94a3b8;
    box-shadow: 0 0 0 2px rgba(12,40,76,.08);
  }

  #contact-page-{{ section.id }} .contact-field.has-error:not(.contact-field--message) .contact-field__control {
    border-color: var(--contact-error);
  }

  #contact-page-{{ section.id }} .contact-page__details {
    position: absolute;
    top: 585px;
    left: 0;
    display: flex;
    width: 700px;
    flex-direction: column;
    gap: 16px;
  }

  #contact-page-{{ section.id }} .contact-page__detail {
    display: flex;
    min-height: 20px;
    align-items: center;
    gap: 8px;
    color: var(--contact-label);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: -.1504px;
    line-height: 20px;
    white-space: nowrap;
  }

  #contact-page-{{ section.id }} .contact-page__detail svg {
    display: block;
    width: 20px;
    height: 20px;
    flex: 0 0 20px;
  }

  #contact-page-{{ section.id }} .contact-page__detail strong { font-weight: 600; }

  #contact-page-{{ section.id }} .contact-page__submit {
    position: absolute;
    top: 717px;
    left: 50%;
    display: flex;
    width: 163px;
    height: 50px;
    align-items: center;
    justify-content: center;
    padding: 0 28px;
    transform: translateX(-50%);
    border: 0;
    border-radius: 100px;
    background: var(--contact-button);
    color: #fff;
    font-size: 24px;
    font-weight: 600;
    line-height: normal;
    white-space: nowrap;
    cursor: pointer;
  }

  #contact-page-{{ section.id }} .contact-page__form-status {
    position: absolute;
    top: 785px;
    left: 50%;
    width: 1090px;
    transform: translateX(-50%);
    color: var(--contact-label);
    font-size: 14px;
    line-height: 20px;
    text-align: center;
  }

  #contact-page-{{ section.id }} .contact-page__form-status--error { color: var(--contact-error); }

  /*
   * Compact desktop: the Figma content canvas is 1440px wide (1920px viewport
   * with 240px gutters). Below 1640px, preserve 100px gutters and scale every
   * design measurement against the remaining content width.
   */
  @media screen and (min-width: 990px) and (max-width: 1639px) {
    #contact-page-{{ section.id }} {
      --contact-desktop-gutter: 100px;
    }

    #contact-page-{{ section.id }} .contact-page__hero {
      height: calc(75vw - 150px);
    }

    #contact-page-{{ section.id }} .contact-page__hero-content {
      top: calc(28.055556vw - 56.111111px);
      left: var(--contact-desktop-gutter);
      width: calc(55.555556vw - 111.111111px);
    }

    #contact-page-{{ section.id }} .contact-page__hero-title {
      width: calc(55.555556vw - 111.111111px);
      font-size: calc(5.555556vw - 11.111111px);
      letter-spacing: calc(-0.138889vw + 0.277778px);
      line-height: calc(7.222222vw - 14.444444px);
    }

    #contact-page-{{ section.id }} .contact-page__hero-copy {
      width: calc(41.666667vw - 83.333333px);
      margin-top: calc(-0.208333vw + 0.416667px);
      font-size: calc(1.388889vw - 2.777778px);
      line-height: calc(2.013889vw - 4.027778px);
    }

    #contact-page-{{ section.id }} .contact-page__button {
      width: calc(19.652778vw - 39.305556px);
      height: calc(3.472222vw - 6.944444px);
      padding-inline: calc(1.944444vw - 3.888889px);
      font-size: calc(1.666667vw - 3.333333px);
    }

    #contact-page-{{ section.id }} .contact-page__hero-content .contact-page__button {
      margin-top: calc(1.388889vw - 2.777778px);
    }

    #contact-page-{{ section.id }} .contact-page__perks {
      height: calc(41.666667vw - 83.333333px);
    }

    #contact-page-{{ section.id }} .contact-page__perks-copy {
      top: calc(11.180556vw - 22.361111px);
      left: var(--contact-desktop-gutter);
      width: calc(34.722222vw - 69.444444px);
      gap: calc(1.388889vw - 2.777778px);
    }

    #contact-page-{{ section.id }} .contact-page__perks-title {
      width: calc(34.722222vw - 69.444444px);
