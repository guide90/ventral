  @media screen and (max-width: 989px) {
    #contact-page-{{ section.id }} .contact-page__hero { height: 600px; }
    #contact-page-{{ section.id }} .contact-page__hero-image { object-fit: cover; }

    #contact-page-{{ section.id }} .contact-page__hero-shade {
      height: 371px;
      background: linear-gradient(180deg, rgba(0,15,34,.28) 0%, rgba(0,15,34,.04) 100%);
    }

    #contact-page-{{ section.id }} .contact-page__hero-content {
      top: 92px;
      left: 12px;
      width: calc(100% - 24px);
      text-align: center;
    }

    #contact-page-{{ section.id }} .contact-page__hero-title {
      width: 100%;
      font-size: 28px;
      letter-spacing: -.56px;
      line-height: 38px;
    }

    #contact-page-{{ section.id }} .contact-page__hero-copy {
      width: 100%;
      margin-top: 12px;
      font-size: 14px;
      line-height: 20px;
    }

    #contact-page-{{ section.id }} .contact-page__button {
      width: 180px;
      height: 35px;
      padding: 0 14px;
      font-size: 16px;
    }

    #contact-page-{{ section.id }} .contact-page__hero-content .contact-page__button { margin-top: 20px; }

    #contact-page-{{ section.id }} .contact-page__perks { height: 461px; }

    #contact-page-{{ section.id }} .contact-page__perks-copy {
      top: 40px;
      left: 12px;
      width: calc(100% - 24px);
      align-items: center;
      gap: 0;
      text-align: center;
    }

    #contact-page-{{ section.id }} .contact-page__perks-title {
      width: 100%;
      font-size: 28px;
      letter-spacing: -.56px;
      line-height: 38px;
    }

    #contact-page-{{ section.id }} .contact-page__perks-text {
      width: 100%;
      min-height: 0;
      margin-top: 12px;
      justify-content: center;
      font-size: 14px;
      line-height: 20px;
    }

    #contact-page-{{ section.id }} .contact-page__perks-copy .contact-page__button { margin-top: 20px; }

    #contact-page-{{ section.id }} .contact-page__perks-media {
      top: 254px;
      left: 12px;
      width: calc(100% - 24px);
      height: 167px;
      border-radius: 10px;
    }

    #contact-page-{{ section.id }} .contact-page__perks-image--desktop { display: none; }
    #contact-page-{{ section.id }} .contact-page__perks-image--mobile { display: block; }

    #contact-page-{{ section.id }} .contact-page__form-section { height: 863px; }

    #contact-page-{{ section.id }} .contact-page__form-heading {
      top: 40px;
      left: 12px;
      width: calc(100% - 24px);
      transform: none;
    }

    #contact-page-{{ section.id }} .contact-page__form-title {
      height: 38px;
      font-size: 28px;
      letter-spacing: -.56px;
      line-height: 38px;
    }

    #contact-page-{{ section.id }} .contact-page__form-copy {
      margin-top: 12px;
      font-size: 14px;
      line-height: 20px;
      white-space: normal;
    }

    #contact-page-{{ section.id }} .contact-page__form {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 863px;
    }

    #contact-page-{{ section.id }} .contact-page__fields {
      top: 170px;
      left: 12px;
      width: calc(100% - 24px);
      grid-template-columns: 1fr;
      grid-template-areas: "name" "email" "message" "phone" "order";
      row-gap: 16px;
    }

    #contact-page-{{ section.id }} .contact-field {
      width: 100%;
      height: 78px;
    }

    #contact-page-{{ section.id }} .contact-field__label {
      font-size: 12px;
      letter-spacing: -.12px;
    }

    #contact-page-{{ section.id }} .contact-field__control {
      padding: 0 16px;
      border-radius: 12px;
      font-size: 14px;
      letter-spacing: -.14px;
      line-height: 20px;
    }

    #contact-page-{{ section.id }} textarea.contact-field__control {
      padding-top: 14px;
      padding-bottom: 14px;
    }

    #contact-page-{{ section.id }} .contact-page__details {
      top: 644px;
      left: 12px;
      width: calc(100% - 24px);
      gap: 8px;
    }

    #contact-page-{{ section.id }} .contact-page__detail {
      min-height: 20px;
      font-size: 10px;
      letter-spacing: -.1px;
      line-height: 20px;
      white-space: normal;
    }

    #contact-page-{{ section.id }} .contact-page__detail svg {
      width: 16px;
      height: 16px;
      flex-basis: 16px;
    }

    #contact-page-{{ section.id }} .contact-page__submit {
      top: 788px;
      width: 100px;
      height: 35px;
      padding: 0 14px;
      font-size: 16px;
    }

    #contact-page-{{ section.id }} .contact-page__form-status {
      top: 833px;
      width: calc(100% - 24px);
      font-size: 12px;
      line-height: 18px;
    }
  }
{% endstyle %}

<section class="contact-page" id="contact-page-{{ section.id }}" data-contact-page>
  <div class="contact-page__hero">
    <picture class="contact-page__hero-picture">
      {%- if hero_image_mobile != blank -%}
        <source
          media="(max-width: 989px)"
          srcset="{{ hero_image_mobile | image_url: width: 750 }}"
        >
      {%- endif -%}
      {%- if hero_image_desktop != blank -%}
        <img
          class="contact-page__hero-image"
          src="{{ hero_image_desktop | image_url: width: 3840 }}"
          alt="{{ section.settings.hero_title | escape }}"
          width="{{ hero_image_desktop.width }}"
          height="{{ hero_image_desktop.height }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    </picture>
    <div class="contact-page__hero-shade" aria-hidden="true"></div>

    <div class="contact-page__hero-content">
      <h1 class="contact-page__hero-title">{{ section.settings.hero_title | escape | newline_to_br }}</h1>
      <p class="contact-page__hero-copy">{{ section.settings.hero_copy | escape }}</p>
      <a class="contact-page__button" href="{{ hero_button_link }}">
        {{- section.settings.hero_button_label | escape -}}
      </a>
    </div>
  </div>

  <div class="contact-page__perks">
    <div class="contact-page__perks-copy">
      <h2 class="contact-page__perks-title">{{ section.settings.perks_title | escape }}</h2>
      <p class="contact-page__perks-text">{{ section.settings.perks_copy | escape }}</p>
      <a class="contact-page__button" href="{{ perks_button_link }}">
        {{- section.settings.perks_button_label | escape -}}
      </a>
    </div>
    <div class="contact-page__perks-media">
      {%- if perks_image_desktop != blank -%}
        <img
          class="contact-page__perks-image--desktop"
          src="{{ perks_image_desktop | image_url: width: 1680 }}"
          alt="{{ perks_image_desktop.alt | default: section.settings.perks_image_alt | escape }}"
          width="{{ perks_image_desktop.width }}"
          height="{{ perks_image_desktop.height }}"
          loading="lazy"
        >
      {%- endif -%}
      {%- if perks_image_mobile != blank -%}
        <img
          class="contact-page__perks-image--mobile"
          src="{{ perks_image_mobile | image_url: width: 702 }}"
          alt="{{ perks_image_mobile.alt | default: section.settings.perks_image_alt | escape }}"
          width="{{ perks_image_mobile.width }}"
          height="{{ perks_image_mobile.height }}"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  </div>

  {% comment %}
  <div class="contact-page__form-section" id="contact-form-{{ section.id }}">
    <div class="contact-page__form-heading">
      <h2 class="contact-page__form-title">{{ section.settings.form_title | escape }}</h2>
      <p class="contact-page__form-copy">{{ section.settings.form_copy | escape }}</p>
    </div>

    {%- form 'customer', id: contact_form_id, class: 'contact-page__form' -%}
      <div class="contact-page__fields">
        <div class="contact-field contact-field--name" data-contact-field="name">
          <label class="contact-field__label" for="ContactName-{{ section.id }}">
            <svg class="contact-field__error-icon" viewBox="0 0 14 14" width="14" height="14" aria-hidden="true" focusable="false">
              <circle cx="7" cy="7" r="6.25" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 3.6v4.1M7 10.35v.05" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span data-contact-label>{{ section.settings.name_label | escape }}</span>
          </label>
          <input
            class="contact-field__control"
            id="ContactName-{{ section.id }}"
            type="text"
            name="contact[first_name]"
            value="{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.name | escape }}{% endif %}"
            placeholder="{{ section.settings.name_placeholder | escape }}"
            autocomplete="name"
            data-contact-input
            required
          >
        </div>

        <div class="contact-field contact-field--email{% if form.errors contains 'email' %} has-error{% endif %}" data-contact-field="email">
          <label class="contact-field__label" for="ContactEmail-{{ section.id }}">
            <svg class="contact-field__error-icon" viewBox="0 0 14 14" width="14" height="14" aria-hidden="true" focusable="false">
              <circle cx="7" cy="7" r="6.25" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 3.6v4.1M7 10.35v.05" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span data-contact-label>{% if form.errors contains 'email' %}Invalid Email{% else %}{{ section.settings.email_label | escape }}{% endif %}</span>
          </label>
          <input
            class="contact-field__control"
            id="ContactEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            data-contact-input
            required
            {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
          >
        </div>

        <div class="contact-field contact-field--message" data-contact-field="message">
          <label class="contact-field__label" for="ContactMessage-{{ section.id }}">
            <svg class="contact-field__error-icon" viewBox="0 0 14 14" width="14" height="14" aria-hidden="true" focusable="false">
              <circle cx="7" cy="7" r="6.25" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 3.6v4.1M7 10.35v.05" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span data-contact-label>{{ section.settings.message_label | escape }}</span>
          </label>
          <textarea
            class="contact-field__control"
            id="ContactMessage-{{ section.id }}"
            name="customer[note]"
            placeholder="{{ section.settings.message_placeholder | escape }}"
            data-contact-input
            required
          >{{ form.body | escape }}</textarea>
        </div>

        <div class="contact-field contact-field--phone" data-contact-field="phone">
          <label class="contact-field__label" for="ContactPhone-{{ section.id }}">
            <span data-contact-label>{{ section.settings.phone_label | escape }}</span>
          </label>
          <input
            class="contact-field__control"
            id="ContactPhone-{{ section.id }}"
            type="tel"
            name="customer[phone]"
            value="{% if form.phone %}{{ form.phone | escape }}{% elsif customer %}{{ customer.phone | escape }}{% endif %}"
            placeholder="{{ section.settings.phone_placeholder | escape }}"
            autocomplete="tel"
            data-contact-input
          >
        </div>

        <div class="contact-field contact-field--order" data-contact-field="order">
          <label class="contact-field__label" for="ContactOrder-{{ section.id }}">
            <span data-contact-label>{{ section.settings.order_label | escape }}</span>
          </label>
          <input
            class="contact-field__control"
            id="ContactOrder-{{ section.id }}"
            type="text"
            name="contact[Order number]"
            placeholder="{{ section.settings.order_placeholder | escape }}"
            data-contact-input
          >
        </div>
      </div>

      <div class="contact-page__details">
        <p class="contact-page__detail">
          <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true" focusable="false">
            <path d="M10 18s6-5.14 6-10A6 6 0 1 0 4 8c0 4.86 6 10 6 10Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="10" cy="8" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <span><strong>Address :</strong> {{ section.settings.address | escape }}</span>
        </p>
        <p class="contact-page__detail">
          <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true" focusable="false">
            <path d="M6.1 2.5 8 6.25 6.55 7.7c.9 2.05 2.6 3.75 4.65 4.65L12.65 10 16.5 11.9v3.25c0 .75-.6 1.35-1.35 1.35C8.7 16.5 3.5 11.3 3.5 4.85c0-.75.6-1.35 1.35-1.35H6.1Z" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linejoin="round"/>
          </svg>
          <span><strong>Phone :</strong> {{ section.settings.phone | escape }}</span>
        </p>
        <p class="contact-page__detail">
          <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true" focusable="false">
            <rect x="2.75" y="4.25" width="14.5" height="11.5" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
            <path d="m3.5 5.25 6.5 5 6.5-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          <span><strong>Email :</strong> {{ section.settings.email | escape }}</span>
        </p>
      </div>

      <button class="contact-page__submit" type="submit">{{ section.settings.submit_label | escape }}</button>

      {%- if form.posted_successfully? -%}
        <p class="contact-page__form-status" role="status">{{ 'contact.form.post_success' | t }}</p>
      {%- endif -%}
      {%- if form.errors -%}
        <div class="contact-page__form-status contact-page__form-status--error" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
  {% endcomment %}
</section>

<script>
  (() => {
    const root = document.getElementById('contact-page-{{ section.id }}');
    if (!root) return;


    const form = root.querySelector('.contact-page__form');
    if (!form || form.dataset.validationBound === 'true') return;
    form.dataset.validationBound = 'true';

    const fields = {
      name: {
        element: form.querySelector('[data-contact-field="name"]'),
        defaultLabel: {{ section.settings.name_label | json }},
        errorLabel: 'Invalid Username',
        valid: (value) => value.trim().length >= 2
      },
      email: {
        element: form.querySelector('[data-contact-field="email"]'),
        defaultLabel: {{ section.settings.email_label | json }},
        errorLabel: 'Invalid Email',
        valid: (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim())
      },
      message: {
        element: form.querySelector('[data-contact-field="message"]'),
        defaultLabel: {{ section.settings.message_label | json }},
        errorLabel: 'Message ( This field is required. )',
        valid: (value) => value.trim().length > 0
      }
    };

    const updateField = (field, showError) => {
      if (!field.element) return true;
      const input = field.element.querySelector('[data-contact-input]');
      const label = field.element.querySelector('[data-contact-label]');
      const valid = field.valid(input.value);
      const hasError = showError && !valid;

      field.element.classList.toggle('has-error', hasError);
      input.setAttribute('aria-invalid', hasError ? 'true' : 'false');
      label.textContent = hasError ? field.errorLabel : field.defaultLabel;
      return valid;
    };

    Object.values(fields).forEach((field) => {
      if (!field.element) return;
      const input = field.element.querySelector('[data-contact-input]');
      input.addEventListener('blur', () => updateField(field, true));
      input.addEventListener('input', () => {
        if (field.element.classList.contains('has-error')) updateField(field, true);
      });
    });

    form.addEventListener('submit', (event) => {
      let firstInvalid = null;
      let valid = true;

      Object.values(fields).forEach((field) => {
        const fieldValid = updateField(field, true);
        if (!fieldValid && !firstInvalid) firstInvalid = field.element.querySelector('[data-contact-input]');
        valid = valid && fieldValid;
      });

      if (!valid) {
        event.preventDefault();
        firstInvalid?.focus();
      }
    });

  })();
</script>

