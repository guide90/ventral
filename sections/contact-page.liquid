    { "type": "text", "id": "order_label", "label": "Order label", "default": "Order number ( Optional )" },
    { "type": "text", "id": "order_placeholder", "label": "Order placeholder", "default": "Enter your Order number" },
    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Join Now" },
    { "type": "textarea", "id": "address", "label": "Address", "default": "9800 International Drive, Suite 120, Orlando, FL, United States, 32819" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "XXXXXXXXXXXXX" },
    { "type": "text", "id": "email", "label": "Email", "default": "pr@ventral.com" }
  ],
  "presets": [
