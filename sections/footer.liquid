        </svg>
      </a>
      <div class="ventral-footer__subscribe-content">
        <h2>{{ section.settings.newsletter_heading | escape }}</h2>
        {%- form 'customer', class: 'ventral-footer__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="FooterEmail-{{ section.id }}">Email address</label>
          <input
            id="FooterEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            required
          >
          <button type="submit" aria-label="Subscribe">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0.671923 6.64623C0.671923 6.98223 0.751923 7.21023 0.911922 7.33023C1.07192 7.45023 1.32792 7.51023 1.67992 7.51023H2.43592C2.77992 7.51023 3.14592 7.51223 3.53392 7.51623C3.92192 7.52023 4.29992 7.52223 4.66792 7.52223H5.54392C5.84792 7.52223 6.08992 7.55223 6.26992 7.61223C6.44992 7.67223 6.53592 7.81023 6.52792 8.02623C6.52792 8.18623 6.53192 8.37623 6.53992 8.59623C6.54792 8.81623 6.55192 9.01023 6.55192 9.17823C6.55192 9.45823 6.62792 9.63623 6.77992 9.71223C6.93192 9.78823 7.12792 9.73423 7.36792 9.55023C7.60792 9.35823 7.89192 9.13223 8.21992 8.87223C8.54792 8.61223 8.88192 8.34623 9.22192 8.07423C9.56192 7.80223 9.89792 7.53423 10.2299 7.27023C10.5619 7.00623 10.8559 6.77423 11.1119 6.57423C11.3519 6.38223 11.4739 6.20023 11.4779 6.02823C11.4819 5.85623 11.3719 5.67823 11.1479 5.49423C10.9239 5.30223 10.6559 5.08023 10.3439 4.82823C10.0319 4.57623 9.70792 4.31623 9.37192 4.04823C9.03592 3.78023 8.70592 3.51423 8.38192 3.25023C8.05792 2.98623 7.76792 2.75023 7.51192 2.54223C7.23192 2.31823 7.00192 2.23223 6.82192 2.28423C6.64192 2.33623 6.55192 2.50623 6.55192 2.79423V3.09423C6.55192 3.20623 6.54992 3.32223 6.54592 3.44223C6.54192 3.56223 6.53792 3.68023 6.53392 3.79623C6.52992 3.91223 6.52792 4.01423 6.52792 4.10223C6.51992 4.30223 6.45592 4.42823 6.33592 4.48023C6.21592 4.53223 6.05192 4.55823 5.84392 4.55823C5.61192 4.55823 5.30792 4.55623 4.93192 4.55223C4.55592 4.54823 4.16392 4.54623 3.75592 4.54623C3.34792 4.54623 2.95192 4.54423 2.56792 4.54023C2.18392 4.53623 1.87192 4.53423 1.63192 4.53423C1.52792 4.53423 1.41992 4.54223 1.30792 4.55823C1.19592 4.57423 1.09392 4.61223 1.00192 4.67223C0.909924 4.73223 0.833922 4.81623 0.773923 4.92423C0.713923 5.03223 0.683923 5.17423 0.683923 5.35023C0.683923 5.56623 0.681923 5.77423 0.677923 5.97423C0.673923 6.17423 0.671923 6.39823 0.671923 6.64623Z" fill="white"/>
            </svg>
          </button>
        {%- endform -%}
      </div>
      <div class="ventral-footer__socials" aria-label="Social media">
        <a href="{{ section.settings.instagram_link | default: '#' }}" aria-label="Instagram">
          <svg
            class="ventral-footer__social-icon ventral-footer__social-icon--instagram"
            viewBox="0 0 19 19"
            aria-hidden="true"
            focusable="false"
          >
            <rect x="1" y="1" width="17" height="17" rx="4.25"/><circle cx="9.5" cy="9.5" r="3.85"/><circle cx="14.4" cy="4.6" r=".8" fill="currentColor" stroke="none"/>
          </svg>
          <span>ventral.official</span>
        </a>
        <a href="{{ section.settings.facebook_link | default: '#' }}" aria-label="Facebook">
          <svg
            class="ventral-footer__social-icon ventral-footer__social-icon--facebook"
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M9.59961 0.700195C14.5147 0.700195 18.4998 4.68457 18.5 9.59961C18.5 14.5148 14.5148 18.5 9.59961 18.5C4.68457 18.4998 0.700195 14.5147 0.700195 9.59961C0.700407 4.6847 4.6847 0.700407 9.59961 0.700195Z" stroke="white" stroke-width="1.4"/>
            <path d="M9.93796 15.0031V9.59589H11.6369L11.9053 7.80398H9.93795L9.93796 6.90547C9.93796 6.4379 10.0839 5.99163 10.723 5.99163H12.0002V4.20312H10.1869C8.66233 4.20312 8.24632 5.25749 8.24632 6.71895V7.80312H7.2002V9.59589H8.24632V15.0031H9.93796Z" fill="white"/>
          </svg>
          <span>Ventral Marine</span>
        </a>
      </div>
    </div>
    <div class="ventral-footer__divider" aria-hidden="true"></div>
    <div class="ventral-footer__links">
      <div>
        <h3>CONTACT</h3>
        <p>
          Email:
          <a href="mailto:{{ section.settings.contact_email | escape }}">
            {{- section.settings.contact_email | escape -}}
          </a>
        </p>
        <p>{{ section.settings.address | escape }}</p>
      </div>
      <div>
        <h3>EXPLORE</h3>
        <a href="{{ section.settings.about_link | default: '/pages/story' }}">About Ventral</a>
        <a href="{{ section.settings.reserve_link | default: 'https://kayak.ventral.com/reserve' }}">Reserve Now</a>
      </div>
      <div>
        <h3>LEGAL</h3>
        <a href="{{ section.settings.terms_link | default: '/policies/terms-of-service' }}">Terms of Service</a>
        <a href="{{ section.settings.privacy_link | default: '/policies/privacy-policy' }}">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .ventral-footer,
  .ventral-footer * {
    box-sizing: border-box;
  }
  .ventral-footer {
    background: #111924;
    color: #f4f8ff;
    font-family: Inter, Arial, sans-serif;
  }
  .ventral-footer__inner {
    display: grid;
    grid-template-columns: 412px 1px 1fr;
    column-gap: 79px;
    width: min(1140px, calc(100% - 64px));
    min-height: 400px;
    margin: 0 auto;
    padding: 100px 0;
  }
  .ventral-footer__subscription {
    min-width: 0;
  }
  .ventral-footer__brand {
    display: flex;
    align-items: center;
    width: fit-content;
    height: 40px;
    color: #f4f8ff;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.04em;
    text-decoration: none;
  }
  .ventral-footer__logo-image {
    display: block;
    flex: 0 0 256px;
    width: 256px;
    max-width: none;
    height: 40px;
    object-fit: contain;
    object-position: left center;
  }
  .ventral-footer__brand-mark {
    width: 42px;
    height: 40px;
    margin-right: 20px;
  }
  .ventral-footer__subscribe-content {
    margin-top: 20px;
  }
  .ventral-footer h2 {
    max-width: 411px;
    margin: 0 0 16px;
    color: #fff;
    font-family: Inter, Arial, sans-serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: none;
  }
  .ventral-footer__form {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 40px;
    padding: 0 12px;
    border: 1px solid #fff;
    border-radius: 8px;
  }
  .ventral-footer__form input {
    min-width: 0;
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    font: 400 14px/1.45 Inter, Arial, sans-serif;
    padding-left: 0;
  }
  .ventral-footer__form input::placeholder {
    color: #a4a4a4;
    opacity: 1;
  }
  .ventral-footer__form button {
    display: grid;
    width: 26px;
    height: 26px;
    place-items: center;
    padding: 0;
    border: 1px solid #fff;
    border-radius: 50%;
    background: transparent;
    color: #fff;
  }
  .ventral-footer__form svg {
    width: 12px;
    height: 12px;
    fill: none;
  }
  .ventral-footer__socials {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 20px;
  }
  .ventral-footer__socials a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.3;
    text-decoration: none;
    white-space: nowrap;
  }
  .ventral-footer__socials svg {
    width: 19px;
    height: 19px;
    fill: none;
    stroke: currentColor;
  }
  .ventral-footer__divider {
    width: 1px;
    height: 200px;
    background: #6d6d6d;
  }
  .ventral-footer__links {
    display: grid;
    grid-template-columns: 180px max-content max-content;
    gap: 100px;
    align-content: start;
  }
  .ventral-footer__links > div {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .ventral-footer__links h3 {
    margin: 0 0 8px;
    color: #f4f8ff;
    font-family: Inter, Arial, sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    text-transform: uppercase;
  }
  .ventral-footer__links p,
  .ventral-footer__links a {
    margin: 0;
    color: #a5a9b7;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.4;
    text-decoration: none;
  }
  @media (max-width: 768px) {
    .ventral-footer__inner {
      display: block;
      width: 100%;
      min-height: 648px;
      padding: 40px 12px;
    }
    .ventral-footer__brand {
      height: 24px;
    }
    .ventral-footer__logo-image {
      flex-basis: 152px;
      width: 152px;
      height: 24px;
    }
    .ventral-footer__brand-mark {
      width: 25px;
      height: 24px;
      margin-right: 8px;
    }
    .ventral-footer__subscribe-content {
      margin-top: 40px;
    }
    .ventral-footer h2 {
      margin-bottom: 16px;
      font-size: 28px;
      line-height: 1.2;
    }
    .ventral-footer__form {
      height: 40px;
    }
    .ventral-footer__socials {
      gap: 16px;
      margin-top: 16px;
    }
    .ventral-footer__socials a {
      gap: 4px;
      font-family: Inter, Arial, sans-serif;
      font-size: 14px;
      line-height: 1.3;
    }
    .ventral-footer__social-icon--instagram {
      width: 18.75px;
      height: 18.75px;
    }
    .ventral-footer__social-icon--facebook {
      width: 19px;
      height: 19px;
    }
    .ventral-footer__links h3,
    .ventral-footer__links p,
    .ventral-footer__links a {
      font-family: Inter, Arial, sans-serif;
    }
    .ventral-footer__divider {
      width: 100%;
      height: 1px;
      margin: 19px 0 20px;
    }
    .ventral-footer__links {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .ventral-footer__links > div {
      gap: 12px;
    }
    .ventral-footer__links h3 {
      margin-bottom: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Ventral Footer",
  "tag": "section",
  "class": "ventral-footer-section",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Subscribe for Launch Updates"
    },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "Enter your email address" },
    { "type": "url", "id": "instagram_link", "label": "Instagram link" },
    { "type": "url", "id": "facebook_link", "label": "Facebook link" },
    { "type": "text", "id": "contact_email", "label": "Contact email", "default": "pr@ventral.com" },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "Address: 9800 International Drive, Suite 120, Orlando, FL, United States, 32819"
    },
    { "type": "url", "id": "about_link", "label": "About link" },
    { "type": "url", "id": "reserve_link", "label": "Reserve link" },
    { "type": "url", "id": "terms_link", "label": "Terms link" },
    { "type": "url", "id": "privacy_link", "label": "Privacy link" }
  ]
}
{% endschema %}
