{% schema %}

{
    "name": "Index verified customers",
    "tag": "section",
    "class": "uk-section uk-section-default uk-padding-remove-top",
    "limit": 1,
    "settings": [
        {
            "type": "select",
            "id": "type",
            "label": "样式布局",
            "default": "index",
            "options": [
                {
                    "value": "index",
                    "label": "首页布局"
                },
                {
                    "value": "active",
                    "label": "活动页布局"
                }
            ]
        },
        {
          "type": "text",
          "id": "heading-pc",
          "label": "Heading PC"
        },
        {
          "type": "text",
          "id": "heading-m",
          "label": "Heading Mobile"
        },
        {
        "type": "text",
          "id": "info",
          "label": "描述"
        },
        {
          "type": "text",
          "id": "more-text",
          "label": "More Text"
        },
        {
          "type": "url",
          "id": "more-url",
          "label": "More URL"
        }
    ],
    "blocks": [
      {
        "name": "Video",
        "type": "video",
        "settings": [
            {
                "type": "image_picker",
                "id": "poster-pc",
                "label": "Poster PC"
            },
            {
                "type": "image_picker",
                "id": "poster-m",
                "label": "Poster Mobile"
            },
            {
                "type": "checkbox",
                "id": "enable_video_looping",
                "label": "Loop video",
                "default": false
            },
            {
                "type": "header",
                "content": "Shopify-hosted video"
            },
            {
                "type": "video",
                "id": "video-pc",
                "label": "Video PC"
            },
            {
                "type": "video",
                "id": "video-m",
                "label": "Video Mobile"
            },
            {
                "type": "header",
                "content": "Or embed video from URL"
            },
            {
                "type": "paragraph",
                "content": "Shows when no Shopify-hosted video is selected"
            },
            {
                "type": "video_url",
                "id": "video_url",
                "accept": ["youtube", "vimeo"],
                "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
                "label": "URL",
                "info": "Use a YouTube or Vimeo URL"
            },
            {
                "type": "text",
                "id": "description",
                "label": "Video alt text",
                "info": "Describe the video for those using screen readers"
            }
        ]
      }
    ],
    "presets": [
        {
            "name": "Index verified customers",
            "settings": {},
            "blocks": [
            ]
        }
    ],
    "locales": {},
    "enabled_on": {
        "templates": ["*"]
    }
}

{% endschema %}

{{ 'Poppins-Bold.ttf' | asset_url | preload_tag: as: 'font', type: 'font/ttf' }}
{{ 'Inter-SemiBold.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }}
{{ 'Inter-Bold.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }}

{%- style -%}
    #shopify-section-{{ section.id }} {
        padding-bottom: 20px;
    }
    #verified-customers .icon-more-arrow-right {
        content: url("data:image/svg+xml,%3Csvg width='6' height='10' viewBox='0 0 6 10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0.699219 0.699951L4.94186 4.94259L0.699219 9.18523' stroke='%2342AFA4' stroke-width='1.4' stroke-linecap='round'/%3E%3C/svg%3E");
    }
    #verified-customers .head h2 {
        font-family: Poppins;
        font-weight: 700;
        font-size: 28px;
        line-height: 120%;
        letter-spacing: 0;
        color: #000000;
    }
    #verified-customers .head .more {
        font-family: Inter;
        font-weight: 600;
        font-size: 16px;
        line-height: 120%;
        color: #42AFA4;
        text-decoration: none;
    }
    #verified-customers .body .uk-border-rounded {
        border-radius: 12px;
    }
    #verified-customers .body .icon-player {
        width: 32px;
        height: 32px;
        background: url(https://cdn.shopify.com/s/files/1/0754/1089/9266/files/player_m.png?v=1768545090);
    }
    #verified-customers deferred-media .video__object {
        display: none;
        cursor: pointer;
    }
    #verified-customers deferred-media iframe {
        width: 100%;
        height: 100%;
    }
    #verified-customers .stretched-link::after {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 1;
        content: "";
    }
    /* 处理滑块项部分显示 */
    @media screen and (max-width: 639.98px) {
        #verified-customers > div > .uk-slider-items.uk-child-width-1-1 > * {
            width: 70%;
        }
    }
    /* #verified-customers > div > .uk-slider-items.uk-child-width-1-1 > * {
        width: 70%;
    }
    @media screen and (min-width: 640px) {
        #verified-customers > div > .uk-slider-items.uk-child-width-1-2\@s > * {
            width: 49.5%;
        }
    }
    @media screen and (min-width: 960px) {
        #verified-customers > div > .uk-slider-items.uk-child-width-1-4\@m > * {
            width: 24.5%;
        }
    } */
    /* 左右两端留白 */
    #verified-customers > div > .uk-slider-items.uk-grid-medium {
        margin-left: 15px;
        margin-right: 15px;
    }
    @media screen and (min-width: 640px) {
        #verified-customers > div > .uk-slider-items.uk-grid-medium {
            margin-left: 60px;
            margin-right: 60px;
        }
    }
    @media screen and (min-width: 960px) {
        #verified-customers > div > .uk-slider-items.uk-grid-medium {
            margin-left: 80px;
            margin-right: 80px;
        }
    }
    /* 原本uk-grid-medium具备“margin-left: -30px;”，当用“.uk-slider-items.uk-grid-medium”来左右两端留白时，改为父级处理 */
    #verified-customers > div:has(.uk-grid-medium),
    #verified-customers > div.uk-slider {
        margin-left: -30px;
    }



    .active-video-info{
        background: #ECF5FF;
        padding-bottom:100px;
    }
    .active-video-info .head .active-info{
        padding:0;
        margin:0;
        font-family: "Inter";
        font-weight: 400;
        font-size: 14px;
        text-align: center;
        color:#1F4E79;
        padding-top:20px;
        padding-bottom:60px;
    }

    @media screen and (max-width: 639.98px) {
        .active-video-info{
            padding-bottom:60px;
        }
        .active-video-info .head h2{
            text-align:center;
            font-size:24px;
            color:#1F4E79;
        }
        .active-video-info .head h2 span{
            font-size:24px;
            color:#1F4E79;
        }
        .active-video-info .head .active-info{
            padding-top:16px;
           padding-bottom:25px;
        }



        #verified-customers > div:has(.uk-grid-medium),
        #verified-customers > div.uk-slider {
            margin-left: -16px;
        }
        #verified-customers .uk-slider-items.uk-grid-medium > * {
            padding-left: 16px;
        }
    }
    @media screen and (min-width: 640px) {
        #shopify-section-{{ section.id }} {
            padding-bottom: 30px;
        }
        #verified-customers .head h2 {
            font-family: Inter;
            font-weight: 700;
            /* font-size: 48px; */
            font-size: 36px;
        }
        #verified-customers .head .more {
            font-size: 18px;
        }
        #verified-customers .body .icon-player {
            width: 46px;
            height: 46px;
            background: url(https://cdn.shopify.com/s/files/1/0754/1089/9266/files/player.png?v=1768476277);
        }
         .active-video-info .head h2{
            font-family: "Poppins";
            font-weight: 700;
            font-size: 46px;
            text-align: center;
            color:#1F4E79;
            padding:0;
            margin:0;
            line-height:1;
         }
         .active-video-info .head h2 span{
             font-family: "Poppins";
            font-weight: 700;
            font-size: 46px;
            text-align: center;
            color:#1F4E79;
            padding:0;
            margin:0;
            line-height:1;
            display:block;
         }
    }
{%- endstyle -%}


<div id="verified-customers" class="{% if section.settings.type =='active' %} active-video-info {% endif %}">

    <div class="head {% if section.settings.type == 'index' %} uk-flex uk-flex-between uk-flex-middle uk-margin uk-container uk-container-expand {% endif %}">
        <h2 class="uk-h2 uk-margin-remove-bottom">
            <span class="uk-visible@s">{{ section.settings.heading-pc }}</span>
            <span class="uk-hidden@s">{{ section.settings.heading-m }}</span>
        </h2>
        {%  if section.settings.info != blank %}  
            <p class="active-info">{{ section.settings.info }}</p>
        {% endif %}
        {%  if section.settings.more-url != blank and section.settings.more-text != blank %} 
            <a class="more uk-flex uk-flex-middle" href="{{ section.settings.more-url }}">
                <span class="uk-text-nowrap">{{ section.settings.more-text }}</span>
                <span class="icon-more-arrow-right uk-margin-small-left"></span>
            </a>
        {% endif %}
    </div>
    <div class="body uk-position-relative" tabindex="-1" uk-slider="finite: true;">
        <div class="uk-slider-items uk-child-width-1-1 uk-child-width-1-2@s uk-child-width-1-4@m uk-grid uk-grid-medium">
          {%- for block in section.blocks -%}
            <div class="outer">
                {%- liquid
                    assign video_pc = block.settings.video-pc
                    assign video_m = block.settings.video-m
                    assign video_pc_id = video_pc.id
                    assign video_m_id = video_m.id
                    assign external_video_id = block.settings.video_url.id
                    assign video_alt = block.settings.video-pc.alt | default: block.settings.video-m.alt
                    assign poster_alt = "Video poster of " | append: video_alt | escape
                    assign player_aria_label = "Load video: " | append: block.settings.description | escape
                -%}
                <deferred-media class="inner uk-display-block uk-position-relative uk-card uk-card-default uk-border-rounded uk-overflow-hidden" data-video-PC-id="{{ video_pc_id }}" data-video-M-id="{{ video_m_id }}">
                    <div class="video__cover">
                        <picture class="poster">
                            <source srcset="{{ block.settings.poster-m | image_url: width: 240, height: 426 }}" media="(max-width: 639.98px)" width="240" height="426">
                            <img class="uk-width-1-1" src="{{ block.settings.poster-pc | image_url: width: 410, height: 600 }}" width="410" height="600" alt="{{ poster_alt | escape }}">
                        </picture>
                        
                        <div class="uk-position-cover uk-flex uk-flex-center uk-flex-middle">
                            <a class="icon-player js-no-transition stretched-link" href="javascript:void(0);" aria-label="{{ player_aria_label }}"></a>
                        </div>
                    </div>
                    <div class="video__object uk-position-cover uk-position-z-index">
                        <template>
                            {%- if block.settings.video-pc == null and block.settings.video-m == null and block.settings.video_url != null -%}
                                {%- liquid
                                    assign loop = ''
                                    if block.settings.enable_video_looping
                                        assign loop = '&loop=1&playlist=' | append: external_video_id
                                    endif
                                -%}
                                {%- if block.settings.video_url.type == 'youtube' -%}
                                    <iframe
                                    src="https://www.youtube.com/embed/{{ external_video_id }}?enablejsapi=1&autoplay=1{{ loop }}"
                                    class="js-youtube"
                                    allow="autoplay; encrypted-media"
                                    allowfullscreen
                                    title="{{ block.settings.description | escape }}"
                                    uk-responsive
                                    ></iframe>
                                {%- else -%}
                                    <iframe
                                    src="https://player.vimeo.com/video/{{ external_video_id }}?autoplay=1{{ loop }}"
                                    class="js-vimeo"
                                    allow="autoplay; encrypted-media"
                                    allowfullscreen
                                    title="{{ block.settings.description | escape }}"
                                    uk-responsive
                                    ></iframe>
                                {%- endif -%}
                            {%- else -%}
                                {%- assign video_pc_source = video_pc.sources | where: 'format', 'mp4' | sort: 'width' | last -%}
                                {%- assign video_pc_url = video_pc_source.url -%}
                                {%- assign video_m_source = video_m.sources | where: 'format', 'mp4' | sort: 'height' | last -%}
                                {%- assign video_m_url = video_m_source.url -%}
                                {%- assign video_pc_preview_image = video_pc.preview_image -%}
                                {%- assign video_m_preview_image = video_m.preview_image -%}
                                <video class="uk-width-1-1 uk-height-1-1" playsinline="playsinline"{%- if block.settings.enable_video_looping %} loop="loop"{%- endif %} muted="muted" preload="metadata">
                                    <source src="{{ video_m_url }}" type="video/mp4" media="(max-width: 639.98px)" width="240" height="426">
                                    <source src="{{ video_pc_url }}" type="video/mp4" width="410" height="600">
                                    <img
                                        src="{{ video_pc_preview_image | image_url: width: 410, height: 600 }}"
                                        srcset="
                                            {{ video_m_preview_image | image_url: width: 240, height: 426 }} 240w,
                                            {{ video_m_preview_image | image_url: width: 480, height: 852 }} 480w,
                                            {{ video_pc_preview_image | image_url: width: 410, height: 600 }} 410w,
                                            {{ video_pc_preview_image | image_url: width: 820, height: 1200 }} 820w
                                        "
                                        sizes="(max-width: 639.98px) 240px,410px" width="auto" height="auto" loading="lazy"
                                        alt="{{ video_alt | escape }}">
                                </video>
                            {%- endif -%}
                        </template>
                    </div>
                </deferred-media>
            </div>
          {%- endfor -%}
        </div>
    </div>
</div>

<script type="module">
(function() {
    function pauseAllMedia() {
        document.querySelectorAll('.js-youtube').forEach((video) => {
            video.contentWindow.postMessage('{"event":"command","func":"' + 'pauseVideo' + '","args":""}', '*');
        });
        document.querySelectorAll('.js-vimeo').forEach((video) => {
            video.contentWindow.postMessage('{"method":"pause"}', '*');
        });
        document.querySelectorAll('video').forEach((video) => video.pause());
        document.querySelectorAll('product-model').forEach((model) => {
            if (model.modelViewerUI) model.modelViewerUI.pause();
        });
    }
    class DeferredMedia extends HTMLElement {
        constructor() {
            super();
            const playerButton = this.querySelector('a.icon-player');
            if (!playerButton) return;
            playerButton.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                this.loadContent();
            });
        }

        loadContent(focus = true) {
            pauseAllMedia();
            if (!this.getAttribute('loaded')) {
                var div = document.createElement('div'),
                    template = this.querySelector('template')
                div.appendChild(template.content.firstElementChild.cloneNode(true))

                var media = template.parentElement.appendChild(div.querySelector('video, model-viewer, iframe'))
                this.setAttribute('loaded', true)
                this.showMedia(media)
                if (focus) media.focus()
                if (media.nodeName == 'VIDEO') {
                    media.muted = false
                    if (!media.oncanplay) {
                        media.oncanplay = function (event) {
                            media.setAttribute('canplay', true)
                            if (media.loop) { //注意重播时也会触发回调，既然循环播放可保持canplay状态不变
                                media.oncanplay = null
                            }
                        }
                    }
                    media.addEventListener('click', (e) => {
                        e.stopPropagation()
                        this.hideMedia(media)
                        if (!media.paused) { // 仅当视频正在播放时才暂停
                            media.pause()
                            media.muted = true
                        }
                    })
                    // force autoplay for safari
                    media.play().catch(err => {
                        this.addEventListener('click', this.manualPlay)
                        this.click() //手动触发
                    })
                }
                if (media.hasAttribute('autoplay')) {
                    this.setMediaObserver()
                }

                // Workaround for safari iframe bug
                const formerStyle = media.getAttribute('style');
                media.setAttribute('style', 'display: block;');
                window.setTimeout(() => {
                    media.setAttribute('style', formerStyle);
                }, 0);
            } else {
                this.manualPlay()
            }
        }

        showMedia(media) {
            if (!media) return
            media.parentElement.style.display = 'block'
        }

        hideMedia(media) {
            if (!media) return
            media.parentElement.style.display = 'none'
        }

        setMediaObserver() {
            var mediaObserver = new IntersectionObserver(function (entries, observer) {
                if (entries[0].intersectionRatio <= 0) return
                var action,
                    media = deferredMedia.lastElementChild
                if (['video', 'audio'].indexOf(media.localName) > -1) {
                    if (entries[0].isIntersecting) {
                        action = media.paused ? 'play' : ''
                    } else {
                        action = media.paused ? '' : 'pause'
                    }
                    switch (action) {
                        case 'play':
                            media.play()
                            break
                        case 'pause':
                            if (media.getAttribute('canplay')) {
                                media.pause()
                            }
                        break
                    }
                }
            }, {threshold: [1]}),
            deferredMedia = this
            mediaObserver.observe(this)
        }

        manualPlay(event) {
            const video = this.querySelector('video')
            if (video && video.paused) {
                this.showMedia(video)
                video.muted = false
                video.play()
            }
        }
    }
    if (!window.customElements.get('deferred-media')) {
        customElements.define('deferred-media', DeferredMedia);
    }
})();
</script>