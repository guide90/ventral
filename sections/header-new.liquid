{%- liquid
  assign logo = section.settings.logo
  assign button_type = section.settings.button_type
  assign button_text = section.settings.button_text
  assign button_link = section.settings.button_link
  assign anchor_id = section.settings.anchor_id | remove: '#'
  assign floating_icon_image = section.settings.floating_icon_image
  assign modal_image = section.settings.modal_image
  assign modal_logo = section.settings.modal_logo | default: logo
  assign modal_id = 'HeaderNewModal-' | append: section.id
  assign modal_form_id = 'HeaderNewModalForm-' | append: section.id
-%}

<header
  class="header-new"
  style="--header-new-bg: {{ section.settings.background_color }}; --header-new-text: {{ section.settings.text_color }}; --header-new-button-bg: {{ section.settings.button_background_color }}; --header-new-button-text: {{ section.settings.button_text_color }}; --header-new-page-width: {{ section.settings.page_width }}px; --header-new-desktop-height: {{ section.settings.height }}px; --header-new-mobile-height: {{ section.settings.mobile_height }}px; --header-new-logo-width: {{ section.settings.logo_width }}px; --header-new-mobile-logo-width: {{ section.settings.mobile_logo_width }}px; --header-new-logo-max-height: {{ section.settings.logo_max_height }}px;">
  <div class="header-new__inner">
    <a class="header-new__logo-link" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      {%- if logo != blank -%}
        {{
          logo
          | image_url: width: section.settings.logo_width
          | image_tag:
            class: 'header-new__logo',
            loading: 'eager',
            widths: '120, 180, 240, 320, 420',
            alt: shop.name
        }}
      {%- else -%}
        <span class="header-new__logo-placeholder">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- if button_text != blank -%}
      {%- if button_type == 'modal' -%}
        <button class="header-new__button" type="button" aria-haspopup="dialog" aria-controls="{{ modal_id }}" data-header-new-modal-open>
          {{ button_text | escape }}
        </button>
      {%- elsif button_type == 'anchor' -%}
        <a class="header-new__button" href="#{{ anchor_id | default: 'MainContent' }}">
          {{ button_text | escape }}
        </a>
      {%- else -%}
        <a class="header-new__button" href="{{ button_link | default: routes.root_url }}">
          {{ button_text | escape }}
        </a>
      {%- endif -%}
    {%- endif -%}
  </div>
</header>
<div class="header-new__spacer" aria-hidden="true"></div>

{%- if floating_icon_image != blank -%}
  {%- if button_type == 'modal' -%}
    <button class="header-new__floating-icon" type="button" aria-label="{{ button_text | default: 'Open' | escape }}" aria-haspopup="dialog" aria-controls="{{ modal_id }}" data-header-new-modal-open>
      {{
        floating_icon_image
        | image_url: width: 120
        | image_tag:
          class: 'header-new__floating-icon-image',
          loading: 'lazy',
          widths: '60, 120',
          alt: button_text
      }}
    </button>
  {%- elsif button_type == 'anchor' -%}
    <a class="header-new__floating-icon" href="#{{ anchor_id | default: 'MainContent' }}" aria-label="{{ button_text | default: 'Jump' | escape }}">
      {{
        floating_icon_image
        | image_url: width: 120
        | image_tag:
          class: 'header-new__floating-icon-image',
          loading: 'lazy',
          widths: '60, 120',
          alt: button_text
      }}
    </a>
  {%- else -%}
    <a class="header-new__floating-icon" href="{{ button_link | default: routes.root_url }}" aria-label="{{ button_text | default: 'Open link' | escape }}">
      {{
        floating_icon_image
        | image_url: width: 120
        | image_tag:
          class: 'header-new__floating-icon-image',
          loading: 'lazy',
          widths: '60, 120',
          alt: button_text
      }}
    </a>
  {%- endif -%}
{%- endif -%}

<script>
  (function() {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    var header = section.querySelector('.header-new');
    if (!header) return;

    var setHeaderHeight = function() {
      section.style.setProperty('--header-new-height', header.offsetHeight + 'px');
    };

    var updateSticky = function() {
      setHeaderHeight();
      section.classList.toggle('is-sticky', window.scrollY > header.offsetHeight);
    };

    setHeaderHeight();
    updateSticky();
    window.addEventListener('scroll', updateSticky, { passive: true });
    window.addEventListener('resize', updateSticky);
  })();
</script>

{%- if button_type == 'modal' -%}
  <div class="header-new-modal" id="{{ modal_id }}" role="dialog" aria-modal="true" aria-labelledby="{{ modal_id }}-Title" aria-hidden="true" data-header-new-modal>
    <button class="header-new-modal__overlay" type="button" aria-label="Close" data-header-new-modal-close></button>
    <div class="header-new-modal__dialog{% if modal_image == blank %} header-new-modal__dialog--no-image{% endif %}">
      <button class="header-new-modal__close" type="button" aria-label="Close" data-header-new-modal-close>
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9.25"></circle><path d="m8.75 8.75 6.5 6.5m0-6.5-6.5 6.5"></path></svg>
      </button>
      {%- if modal_image != blank -%}
        <div class="header-new-modal__media">
          {{
            modal_image
            | image_url: width: 1000
            | image_tag:
              class: 'header-new-modal__image',
              loading: 'lazy',
              widths: '360, 540, 720, 1000',
              sizes: '(max-width: 767px) calc(100vw - 48px), 42vw',
              alt: modal_image.alt
          }}
        </div>
      {%- endif -%}
      <div class="header-new-modal__body">
        {%- if modal_logo != blank -%}
          {{
            modal_logo
            | image_url: width: 320
            | image_tag:
              class: 'header-new-modal__logo',
              loading: 'lazy',
              widths: '120, 180, 240, 320',
              alt: shop.name
          }}
        {%- else -%}
          <div class="header-new-modal__brand">{{ shop.name }}</div>
        {%- endif -%}

        {%- if section.settings.modal_title != blank -%}
          <h2 class="header-new-modal__title" id="{{ modal_id }}-Title">{{ section.settings.modal_title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.modal_content != blank -%}
          <div class="header-new-modal__content rte">
            {{ section.settings.modal_content }}
          </div>
        {%- endif -%}

        {%- form 'customer', id: modal_form_id, class: 'header-new-modal__form' -%}
          <input type="hidden" name="contact[tags]" value="{{ section.settings.modal_customer_tags | escape }}">
          {%- if form.posted_successfully? -%}
            <p class="header-new-modal__message" tabindex="-1">{{ 'general.newsletter_form.newsletter_confirmation' | t }}</p>
          {%- else -%}
            {%- if form.errors -%}
              <div class="header-new-modal__message header-new-modal__message--error">{{ form.errors | default_errors }}</div>
            {%- endif -%}
            <label class="visually-hidden" for="{{ modal_form_id }}-Email">{{ section.settings.modal_email_placeholder | escape }}</label>
            <div class="header-new-modal__field">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><rect x="3" y="5" width="18" height="14" rx="1.5"></rect><path d="m4 7 8 6 8-6"></path></svg>
              <input
                id="{{ modal_form_id }}-Email"
                type="email"
                name="contact[email]"
                value="{% if customer %}{{ customer.email }}{% endif %}"
                placeholder="{{ section.settings.modal_email_placeholder | escape }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required>
            </div>
            <button class="header-new-modal__submit" type="submit" name="commit">{{ section.settings.modal_button_label | escape }}</button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>

  <script>
    (function() {
      var section = document.getElementById('shopify-section-{{ section.id }}');
      if (!section) return;

      var modal = section.querySelector('[data-header-new-modal]');
      var openButtons = document.querySelectorAll('[data-header-new-modal-open]');
      var closeButtons = section.querySelectorAll('[data-header-new-modal-close]');
      if (!modal || !openButtons.length) return;
      var lastTrigger = null;

      var openModal = function(event) {
        lastTrigger = event.currentTarget;
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.documentElement.classList.add('js-drawer-open');
        window.requestAnimationFrame(function() {
          var focusTarget = modal.querySelector('input:not([type="hidden"]), [data-header-new-modal-close]');
          if (focusTarget) focusTarget.focus();
        });
      };

      var closeModal = function() {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.documentElement.classList.remove('js-drawer-open');
        if (lastTrigger) lastTrigger.focus();
      };

      openButtons.forEach(function(button) {
        button.setAttribute('aria-controls', modal.id);
        button.addEventListener('click', openModal);
      });
      closeButtons.forEach(function(button) {
        button.addEventListener('click', closeModal);
      });

      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && modal.classList.contains('is-open')) {
          closeModal();
        }
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Header new",
  "tag": "section",
  "class": "header-new-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "default": 190,
      "min": 80,
      "max": 360,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_logo_width",
      "label": "Mobile logo width",
      "default": 150,
      "min": 80,
      "max": 260,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "label": "Logo max height",
      "default": 42,
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Find a dealer"
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "Button action",
      "default": "link",
      "options": [
        {
          "value": "link",
          "label": "Link"
        },
        {
          "value": "modal",
          "label": "Popup"
        },
        {
          "value": "anchor",
          "label": "Anchor"
        }
      ]
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "floating_icon_image",
      "label": "Floating icon image"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Enter the target element ID without #, for example: launch-updates"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Popup title",
      "default": "Stay Connected with Ventral"
    },
    {
      "type": "liquid",
      "id": "modal_content",
      "label": "Popup content",
      "default": "<p>Be the first to know about new product drops, exclusive offers, and more from Ventral. Enter your email address.</p>"
    },
    {
      "type": "image_picker",
      "id": "modal_image",
      "label": "Popup image"
    },
    {
      "type": "image_picker",
      "id": "modal_logo",
      "label": "Popup logo",
      "info": "Uses the header logo when left blank."
    },
    {
      "type": "text",
      "id": "modal_email_placeholder",
      "label": "Popup email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "modal_button_label",
      "label": "Popup button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "modal_customer_tags",
      "label": "Popup customer tags",
      "default": "newsletter, popup"
    },
    {
      "type": "range",
      "id": "page_width",
      "label": "Page width",
      "default": 1440,
      "min": 960,
      "max": 1800,
      "step": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Desktop height",
      "default": 56,
      "min": 44,
      "max": 96,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "default": 52,
      "min": 44,
      "max": 80,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bottom_bar_height",
      "label": "Bottom bar height",
      "default": 4,
      "min": 0,
      "max": 12,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Header new"
    }
  ]
}
{% endschema %}
