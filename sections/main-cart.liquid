{%- liquid
  assign cart_has_sold_out = false
  for item in cart.items
    if item.variant and item.variant.available == false
      assign cart_has_sold_out = true
    endif
  endfor

  assign cart_total_discounts = cart.total_discounts | money
  assign cart_item_count_text = cart.item_count | append: ' items'
  if cart.item_count == 1
    assign cart_item_count_text = '1 item'
  endif
-%}

<div class="ventral-cart{% if cart.item_count == 0 %} is-empty{% endif %}">
  <div class="ventral-cart__wrap">
    <header class="ventral-cart__header">
      <h1 class="ventral-cart__title">My Cart:</h1>
      <span class="ventral-cart__count">{{ cart_item_count_text }}</span>
    </header>

    <div class="cart__empty-text ventral-cart__empty">
      <div class="ventral-cart__empty-icon" aria-hidden="true">
        {{ 'icon.cart.svg' | inline_asset_content }}
      </div>
      <p>No results found. Please <a href="{{ routes.all_products_collection_url }}">add some items.</a></p>
    </div>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate data-location="page" id="CartPageForm" class="ventral-cart__form">
        <div class="ventral-cart__layout">
          <div class="ventral-cart__items-card">
            <div data-products>
              <div class="cart__items"
                data-count="{{ cart.item_count }}"
                {% if cart.total_discounts > 0 %}
                  data-cart-savings="{{ cart.total_discounts }}"
                {% endif %}
                data-cart-subtotal="{{ cart.total_price }}">
                {%- for item in cart.items -%}
                  {%- render 'cart-item', product: item, sizeVariable: '150px', fallback: '90px' -%}
                {%- endfor -%}
              </div>
            </div>
          </div>

          <aside class="ventral-cart__summary-card" aria-label="Cart summary">
            <div class="ventral-cart__summary-inner">
              <div class="ventral-cart__totals">
                <div class="ventral-cart__total-row ventral-cart__total-row--order">
                  <span>Order Total:<small>{{ cart_item_count_text }}</small></span>
                  <strong>{{ cart.original_total_price | money }}</strong>
                </div>

                <div class="ventral-cart__total-row ventral-cart__total-row--saving{% unless cart.total_discounts > 0 %} hide{% endunless %}" data-summary-savings>
                  <span>Total savings</span>
                  <strong data-summary-savings-amount>{{ cart_total_discounts }}</strong>
                </div>
                <div class="cart__item-row cart__savings hide" data-savings></div>

                <div data-discounts class="ventral-cart__discounts">
                  <div class="cart__discounts{% if cart.cart_level_discount_applications == blank %} hide{% endif %}">
                    {%- for cart_discount in cart.cart_level_discount_applications -%}
                      <div class="ventral-cart__total-row ventral-cart__total-row--discount">
                        <span>{{ cart_discount.title }}</span>
                        <strong>-{{ cart_discount.total_allocated_amount | money }}</strong>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>

                <div class="ventral-cart__total-row ventral-cart__total-row--fee">
                  <span>&#25910;&#36153;&#26679;&#24335;/&#26080;&#23601;&#38544;&#34255;</span>
                  <strong>$0.00</strong>
                </div>

                <div class="ventral-cart__subtotal-row cart__item-sub cart__item-row">
                  <span class="cart__subtotal">Subtotal:</span>
                  <strong data-subtotal>{{ cart.total_price | money }}</strong>
                </div>
              </div>

              <div class="ventral-cart__notes">
                {%- if settings.cart_notes_enable -%}
                  <details class="ventral-cart__notes-details"{% if cart.note != blank %} open{% endif %}>
                    <summary>
                      <span>Add order notes</span>
                      {%- if cart.note != blank -%}
                        <button type="button" class="ventral-cart__note-clear" data-cart-note-clear>Clear</button>
                      {%- endif -%}
                    </summary>
                    <textarea name="note" class="input-full cart-notes" id="CartNote" placeholder="Add remarks...">{{ cart.note }}</textarea>
                  </details>
                {%- endif -%}

                <div class="ventral-cart__shipping-note">
                  Shipping,Taxes, and discounts are applied at checkout
                </div>
              </div>

              {%- if settings.cart_terms_conditions_enable -%}
                <div class="cart__item-row cart__terms cart__terms--right">
                  <input type="checkbox" id="CartTerms" class="cart__terms-checkbox">
                  <label for="CartTerms">
                    {% if settings.cart_terms_conditions_page != blank %}
                      {{ 'cart.general.terms_html' | t: url: settings.cart_terms_conditions_page.url }}
                    {% else %}
                      {{ 'cart.general.terms' | t }}
                    {% endif %}
                  </label>
                </div>
              {%- endif -%}

              <div class="cart__checkout-wrapper ventral-cart__checkout-wrapper">
                <button
                  type="submit"
                  name="checkout"
                  {% if settings.cart_terms_conditions_enable %} data-terms="CartPageAgree"{% endif %}
                  class="btn btn--no-animate cart__checkout ventral-cart__checkout{% if cart_has_sold_out %} ventral-cart__checkout--disabled{% endif %}"
                  {% if cart_has_sold_out %}disabled aria-disabled="true"{% endif %}>
                  {%- if cart_has_sold_out -%}
                    <span>sold out</span>
                    <small>Choose another item</small>
                  {%- else -%}
                    Check out
                  {%- endif -%}
                </button>

                {%- if additional_checkout_buttons and settings.cart_additional_buttons and cart_has_sold_out == false -%}
                  <div class="additional-checkout-buttons additional-checkout-buttons--vertical">{{ content_for_additional_checkout_buttons }}</div>
                {%- endif -%}
              </div>
            </div>
          </aside>
        </div>

        <div class="ventral-cart__sticky">
          <div class="ventral-cart__sticky-total">
            <span>Subtotal:</span>
            <strong>
              <small data-sticky-savings{% unless cart.total_discounts > 0 %} hidden{% endunless %}>-{{ cart_total_discounts }}</small>
              <span data-subtotal-sticky>{{ cart.total_price | money }}</span>
            </strong>
          </div>
          <button
            type="submit"
            name="checkout"
            class="btn btn--no-animate cart__checkout ventral-cart__sticky-checkout{% if cart_has_sold_out %} ventral-cart__checkout--disabled{% endif %}"
            {% if cart_has_sold_out %}disabled aria-disabled="true"{% endif %}>
            {%- if cart_has_sold_out -%}
              <span>sold out</span>
              <small>Choose another item</small>
            {%- else -%}
              Check out
            {%- endif -%}
          </button>
        </div>
      </form>
    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    function syncVentralCart() {
      var cart = document.querySelector('.ventral-cart');
      if (!cart) return;

      var subtotal = cart.querySelector('[data-subtotal]');
      var stickySubtotal = cart.querySelector('[data-subtotal-sticky]');
      if (subtotal && stickySubtotal) {
        stickySubtotal.textContent = subtotal.textContent;
      }

      var items = cart.querySelector('.cart__items');
      var count = items ? parseInt(items.dataset.count || '0', 10) : 0;
      var countText = count === 1 ? '1 item' : count + ' items';
      cart.querySelectorAll('.ventral-cart__count, .ventral-cart__total-row--order small').forEach(function(node) {
        node.textContent = countText;
      });

      var hasSoldOut = !!cart.querySelector('.ventral-cart-item--sold-out');
      cart.querySelectorAll('.ventral-cart__checkout, .ventral-cart__sticky-checkout').forEach(function(button) {
        button.disabled = hasSoldOut;
        button.setAttribute('aria-disabled', hasSoldOut ? 'true' : 'false');
        button.classList.toggle('ventral-cart__checkout--disabled', hasSoldOut);
        button.innerHTML = hasSoldOut ? '<span>sold out</span><small>Choose another item</small>' : 'Check out';
      });
    }

    function syncSavings(cartData) {
      var cart = document.querySelector('.ventral-cart');
      if (!cart || !cartData || !window.theme || !theme.Currency) return;

      var savings = cartData.total_discount || cartData.total_discounts || 0;
      var summary = cart.querySelector('[data-summary-savings]');
      var summaryAmount = cart.querySelector('[data-summary-savings-amount]');
      var stickySavings = cart.querySelector('[data-sticky-savings]');
      var formatted = theme.Currency.formatMoney(savings, theme.settings.moneyFormat);

      if (summary) {
        summary.classList.toggle('hide', savings <= 0);
      }
      if (summaryAmount) {
        summaryAmount.textContent = formatted;
      }
      if (stickySavings) {
        stickySavings.textContent = '-' + formatted;
        stickySavings.hidden = savings <= 0;
      }
    }

    document.addEventListener('click', function(event) {
      var clear = event.target.closest('[data-cart-note-clear]');
      if (!clear) return;
      event.preventDefault();
      var note = document.getElementById('CartNote');
      if (!note) return;
      note.value = '';
      note.dispatchEvent(new Event('change', { bubbles: true }));
    });

    var products = document.querySelector('.ventral-cart [data-products]');
    if (products) {
      new MutationObserver(syncVentralCart).observe(products, { childList: true, subtree: true });
    }
    document.addEventListener('cart:quantity.cart-page', function() {
      window.setTimeout(syncVentralCart, 300);
    });
    document.addEventListener('cart:updated', function(event) {
      syncSavings(event.detail && event.detail.cart);
      window.setTimeout(syncVentralCart, 50);
    });
    syncVentralCart();
  })();
</script>

{% schema %}
{
  "name": "t:sections.main-cart.name"
}
{% endschema %}
